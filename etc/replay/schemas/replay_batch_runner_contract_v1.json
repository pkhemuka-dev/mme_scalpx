  "required_run_request_fields": [
    "schema_version",
    "run_id",
    "scope",
    "date",
    "dates",
    "start_time",
    "end_time",
    "scenario_id",
    "paper_armed_approved",
    "live_trading_approved",
    "production_doctrine_changed"
  ],
