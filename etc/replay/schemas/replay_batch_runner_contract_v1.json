{
  "schema_version": "replay_batch_runner_contract_v1",
  "purpose": "Replay-only batch/date-range/window/scenario runner and artifact materialization contract.",
  "replay_only": true,
  "paper_armed_approved": false,
  "live_trading_approved": false,
  "execution_arming_created": false,
  "broker_calls_allowed": false,
  "live_redis_writes_allowed": false,
  "real_order_intent_allowed": false,
