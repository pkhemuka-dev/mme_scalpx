# =============================================================================
# ScalpX MME — Frozen Runtime Environment Template
# File: etc/project.env.example
#
# Purpose
# -------
# Canonical non-secret environment template for the MME runtime.
# This file documents every expected environment variable category required
# for startup, service composition, ops tooling, logging, Redis transport,
# broker/login integration, and session control.
#
# Rules
# -----
# - Copy this file to: etc/project.env
# - Do NOT commit live secrets into version control
# - Empty values below indicate "must be filled in project.env"
# - Values here are examples/templates only
# - settings.py remains the runtime parser and validator
# =============================================================================


# =============================================================================
# PROJECT IDENTITY
# =============================================================================

# Stable project identifier.
SCALPX_PROJECT_NAME=mme_scalpx

# Runtime environment label: dev | sim | paper | live
SCALPX_ENV=dev

# Human-readable deployment/site label for logs and ops.
SCALPX_SITE=local

# Instance name used in logs / heartbeats / lock-owner identity.
SCALPX_INSTANCE_NAME=mme-main


# =============================================================================
# PATHS
# =============================================================================

# Absolute project root.
SCALPX_PROJECT_ROOT=/home/<user>/scalpx/projects/mme_scalpx

# Python package root containing app/mme_scalpx.
SCALPX_APP_ROOT=/home/<user>/scalpx/projects/mme_scalpx/app

# Virtual environment root.
SCALPX_VENV=/home/<user>/scalpx/projects/mme_scalpx/.venv

# Directory for logs written by file handlers and ops tooling.
SCALPX_LOG_DIR=/home/<user>/scalpx/projects/mme_scalpx/logs

# Directory for pid/run artifacts if used by ops wrappers.
SCALPX_RUN_DIR=/home/<user>/scalpx/projects/mme_scalpx/run

# Directory for durable report outputs / exports.
SCALPX_REPORT_DIR=/home/<user>/scalpx/projects/mme_scalpx/reports

# Directory for ops-generated snapshots / audit exports / replay inputs.
SCALPX_DATA_DIR=/home/<user>/scalpx/projects/mme_scalpx/data


# =============================================================================
# CONFIG FILE PATHS
# =============================================================================

# Logging configuration.
SCALPX_LOGGING_CONFIG=/home/<user>/scalpx/projects/mme_scalpx/etc/logging.yaml

# Instrument / symbol metadata file.
SCALPX_SYMBOLS_FILE=/home/<user>/scalpx/projects/mme_scalpx/etc/symbols.yaml

# Strategy tunables file.
SCALPX_PARAMS_FILE=/home/<user>/scalpx/projects/mme_scalpx/etc/params_mme.yaml

# Risk policy file.
SCALPX_RISK_LIMITS_FILE=/home/<user>/scalpx/projects/mme_scalpx/etc/risk_limits.yaml

# Optional runtime/session policy file.
SCALPX_RUNTIME_CONFIG_FILE=/home/<user>/scalpx/projects/mme_scalpx/etc/runtime.yaml

# Optional execution policy file.
SCALPX_EXECUTION_CONFIG_FILE=/home/<user>/scalpx/projects/mme_scalpx/etc/execution.yaml


# =============================================================================
# RUNTIME MODE
# =============================================================================

# Master runtime mode: paper | live | replay
SCALPX_RUNTIME_MODE=paper

# Master kill switch for entry trading.
# 1 = allow normal entry/exit behavior subject to risk and health
# 0 = block fresh entries; exits still expected to be allowed by services
SCALPX_TRADING_ENABLED=0

# Whether the runtime should fail startup outside allowed session windows.
SCALPX_ENFORCE_SESSION_WINDOW=1

# Default timezone for session, logs, and schedule-sensitive operations.
SCALPX_TIMEZONE=Asia/Kolkata

# Date/session label override, normally blank. Ops may set explicitly for replay/audit.
SCALPX_SESSION_LABEL=

# Replay speed multiplier. Use 1.0 for real-time replay pacing if supported.
SCALPX_REPLAY_SPEED=1.0


# =============================================================================
# SERVICE ENABLEMENT
# =============================================================================

# Service toggles allow controlled startup composition without code edits.
SCALPX_ENABLE_FEEDS=1
SCALPX_ENABLE_FEATURES=1
SCALPX_ENABLE_STRATEGY=1
SCALPX_ENABLE_EXECUTION=1
SCALPX_ENABLE_RISK=1
SCALPX_ENABLE_MONITOR=1
SCALPX_ENABLE_REPORT=1

# Optional startup behavior.
SCALPX_BOOTSTRAP_GROUPS_ON_START=0
SCALPX_RUN_PREFLIGHT_ON_START=1


# =============================================================================
# LOGGING
# =============================================================================

# Root log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
SCALPX_LOG_LEVEL=INFO

# Console log level override, blank means use global/root policy.
SCALPX_CONSOLE_LOG_LEVEL=

# File log level override, blank means use global/root policy.
SCALPX_FILE_LOG_LEVEL=

# Whether JSON logging is enabled if supported by logging config.
SCALPX_LOG_JSON=0

# Log file basename stem.
SCALPX_LOG_FILE_BASENAME=mme_scalpx

# Retention days for file logs if consumed by config/tooling.
SCALPX_LOG_RETENTION_DAYS=14


# =============================================================================
# REDIS CONNECTION
# =============================================================================

# Redis host or IP.
SCALPX_REDIS_HOST=

# Redis port.
SCALPX_REDIS_PORT=6379

# Redis database index.
SCALPX_REDIS_DB=0

# Redis username if ACL is used.
SCALPX_REDIS_USERNAME=

# Redis password / token. KEEP EMPTY IN TEMPLATE.
SCALPX_REDIS_PASSWORD=

# Use TLS for Redis connection: 1=yes, 0=no
SCALPX_REDIS_TLS=1

# TLS certificate requirements: required | optional | none
SCALPX_REDIS_TLS_CERT_REQS=required

# Optional CA cert path for Redis TLS.
SCALPX_REDIS_CA_CERT=

# Optional client cert path.
SCALPX_REDIS_CLIENT_CERT=

# Optional client key path.
SCALPX_REDIS_CLIENT_KEY=

# Socket connect timeout in seconds.
SCALPX_REDIS_CONNECT_TIMEOUT_SEC=5

# Socket read timeout in seconds.
SCALPX_REDIS_SOCKET_TIMEOUT_SEC=5

# Health ping interval to Redis in seconds if used by runtime.
SCALPX_REDIS_HEALTHCHECK_INTERVAL_SEC=30


# =============================================================================
# REDIS LOCK / HEARTBEAT POLICY
# =============================================================================

# Singleton execution lock TTL in milliseconds.
SCALPX_EXECUTION_LOCK_TTL_MS=30000

# Lock refresh cadence in milliseconds.
SCALPX_EXECUTION_LOCK_REFRESH_MS=10000

# Default heartbeat TTL in milliseconds.
SCALPX_HEARTBEAT_TTL_MS=15000

# Heartbeat publish cadence in milliseconds.
SCALPX_HEARTBEAT_INTERVAL_MS=5000

# Consider heartbeat stale after this many milliseconds.
SCALPX_HEARTBEAT_STALE_AFTER_MS=20000


# =============================================================================
# BROKER / EXCHANGE INTEGRATION
# =============================================================================

# Broker identifier used by integration layer, e.g. dhan | zerodha | mock
SCALPX_BROKER_NAME=mock

# Exchange code for primary instrument universe.
SCALPX_EXCHANGE=NSE

# Segment for futures/options routing if required by broker adapter.
SCALPX_DERIVATIVES_SEGMENT=NFO

# Broker client/account identifier. KEEP EMPTY IN TEMPLATE.
SCALPX_BROKER_CLIENT_ID=

# Broker account/user login. KEEP EMPTY IN TEMPLATE.
SCALPX_BROKER_USER_ID=

# Broker vendor/API key. KEEP EMPTY IN TEMPLATE.
SCALPX_BROKER_API_KEY=

# Broker API secret/app secret. KEEP EMPTY IN TEMPLATE.
SCALPX_BROKER_API_SECRET=

# Redirect URI or callback URI if broker login flow requires it.
SCALPX_BROKER_REDIRECT_URI=

# Optional vendor-specific app id / tenant id.
SCALPX_BROKER_APP_ID=


# =============================================================================
# AUTH / TOKEN / SECRET FILES
# =============================================================================

# Broker credentials env file.
SCALPX_BROKER_CREDENTIALS_FILE=/home/<user>/scalpx/projects/mme_scalpx/secrets/broker_credentials.env

# Persistent session token JSON path.
SCALPX_SESSION_TOKEN_FILE=/home/<user>/scalpx/projects/mme_scalpx/secrets/session_token.json

# Generic API key JSON path for integrations if used.
SCALPX_API_KEYS_FILE=/home/<user>/scalpx/projects/mme_scalpx/secrets/api_keys.json

# Token refresh skew in seconds before expiry.
SCALPX_TOKEN_REFRESH_SKEW_SEC=300

# Fail startup if login/session material is absent.
SCALPX_REQUIRE_VALID_LOGIN=0


# =============================================================================
# FEEDS / MARKET DATA
# =============================================================================

# Primary underlying/root symbol family.
SCALPX_UNDERLYING=NIFTY

# Primary futures symbol alias used internally by instruments layer.
SCALPX_PRIMARY_FUTURE_ALIAS=NIFTY

# Primary options root alias used internally by instruments layer.
SCALPX_PRIMARY_OPTIONS_ROOT=NIFTY

# Tick stale threshold for feeds health.
SCALPX_FEED_STALE_AFTER_MS=3000

# Max allowed malformed packets before health downgrade if used.
SCALPX_FEED_ERROR_BURST_LIMIT=10

# Order book depth expected from adapter.
SCALPX_BOOK_DEPTH_LEVELS=5

# Whether feeds runtime should subscribe automatically at startup.
SCALPX_AUTO_SUBSCRIBE_FEEDS=1


# =============================================================================
# STRATEGY / RISK / EXECUTION GUARDRAILS
# =============================================================================

# Hard gate for live broker order submission.
# 0 = forbid live order placement even if runtime mode is live
# 1 = permit subject to internal policy
SCALPX_ALLOW_LIVE_ORDERS=0

# Startup execution mode hint: NORMAL | EXIT_ONLY | DEGRADED | FATAL
SCALPX_STARTUP_EXECUTION_MODE=NORMAL

# Force system into exit-only mode at startup.
SCALPX_STARTUP_EXIT_ONLY=0

# Require flat state before session start.
SCALPX_REQUIRE_FLAT_ON_START=0

# Require flat state at controlled shutdown.
SCALPX_REQUIRE_FLAT_ON_STOP=1

# Square-off lead time in seconds before configured market close if used.
SCALPX_SQUARE_OFF_BUFFER_SEC=300

# Max broker order wait timeout in seconds for synchronous waits if any.
SCALPX_ORDER_TIMEOUT_SEC=10

# Default paper fill latency in milliseconds for paper/sim mode if used.
SCALPX_PAPER_FILL_LATENCY_MS=300


# =============================================================================
# REPORTING / AUDIT
# =============================================================================

# Enable report service output.
SCALPX_ENABLE_REPORT_OUTPUT=1

# Write end-of-day summary artifacts.
SCALPX_EOD_REPORT_ENABLED=1

# Persist stream/state audit exports during closeout.
SCALPX_AUDIT_EXPORT_ENABLED=1

# Default audit export format: jsonl | json | csv
SCALPX_AUDIT_EXPORT_FORMAT=jsonl

# Retention days for reports / exports if ops tooling uses it.
SCALPX_REPORT_RETENTION_DAYS=30


# =============================================================================
# SYSTEMD / OPS INTEGRATION
# =============================================================================

# systemd unit base name used by wrappers/docs.
SCALPX_SYSTEMD_MAIN_UNIT=scalpx-mme.service

# Preflight unit name.
SCALPX_SYSTEMD_PREFLIGHT_UNIT=scalpx-mme-preflight.service

# Open-session unit name.
SCALPX_SYSTEMD_OPEN_UNIT=scalpx-mme-open.service

# Close-session unit name.
SCALPX_SYSTEMD_CLOSE_UNIT=scalpx-mme-close.service

# Health sweep unit name.
SCALPX_SYSTEMD_HEALTH_UNIT=scalpx-mme-health.service


# =============================================================================
# DEVELOPMENT / SAFETY SWITCHES
# =============================================================================

# Enable verbose debug assertions / extra validation if implemented.
SCALPX_DEBUG=0

# Dry-run ops commands without publishing or mutating state where supported.
SCALPX_OPS_DRY_RUN=0

# Permit destructive ops actions from CLI tools, e.g. flatten command.
SCALPX_ALLOW_DESTRUCTIVE_OPS=0

# Strict startup mode:
# 1 = fail on any warning-class readiness issue
# 0 = fail only on hard errors
SCALPX_STRICT_STARTUP=1


# =============================================================================
# NOTES
# =============================================================================
#
# 1. Copy to etc/project.env and replace <user> plus all empty required fields.
# 2. Do not keep real passwords, API secrets, or session tokens in this template.
# 3. Paths here should match the frozen project tree.
# 4. settings.py remains the sole runtime authority for parsing and validation.
# 5. Future additions must be documented here before being treated as supported.
#
# =============================================================================