#!/usr/bin/env python3
"""
bin/replay_compare.py

Freeze-grade replay comparison CLI for locked-vs-shadow studies.

Responsibilities
----------------
- load comparison profile + shadow override pack
- load baseline/shadow frame exports
- compute comparison metrics
- build differential artifacts
- write the canonical comparison artifact pack
- optionally build 20/21 comparison summary artifacts from baseline/shadow run summaries

This script does not:
- execute replay runs
- recompute run summaries
- mutate production doctrine
"""

from __future__ import annotations

import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parents[1]
if str(PROJECT_ROOT) not in sys.path:
    sys.path.insert(0, str(PROJECT_ROOT))

import argparse
import json
import subprocess
import sys
from pathlib import Path
from typing import Any

# Ensure project root is importable when running as a script:
#   .venv/bin/python bin/replay_compare.py ...
PROJECT_ROOT = Path(__file__).resolve().parents[1]
if str(PROJECT_ROOT) not in sys.path:
    sys.path.insert(0, str(PROJECT_ROOT))

import yaml

from app.mme_scalpx.replay.differential import (
    build_differential_artifacts,
    differential_artifacts_to_dict,
)
from app.mme_scalpx.replay.metrics import (
    comparison_metrics_to_dict,
    compute_comparison_metrics,
)
from app.mme_scalpx.replay.overrides import (
    flatten_shadow_override_pack,
    load_shadow_override_pack,
)


class ReplayCompareCliError(RuntimeError):
    """CLI-level replay comparison error."""


def main() -> int:
    args = _parse_args()

    profile = _load_yaml_file(args.profile)
    shadow_pack = load_shadow_override_pack(args.shadow_override)

    baseline_frames = _load_json_list(args.baseline_frames, label="baseline_frames")
    shadow_frames = _load_json_list(args.shadow_frames, label="shadow_frames")

    metrics_bundle = compute_comparison_metrics(
        baseline_frames=baseline_frames,
        shadow_frames=shadow_frames,
    )
    differential = build_differential_artifacts(
        baseline_frames=baseline_frames,
        shadow_frames=shadow_frames,
        metrics_bundle=metrics_bundle,
        baseline_label=str(
            profile.get("experiment", {}).get("baseline_label", "baseline_locked")
        ),
        shadow_label=shadow_pack.override_pack_id,
    )

    output_root = Path(args.output_root).expanduser().resolve()
    output_root.mkdir(parents=True, exist_ok=True)

    metrics_dict = comparison_metrics_to_dict(metrics_bundle)
    differential_dict = differential_artifacts_to_dict(differential)
    override_dict = flatten_shadow_override_pack(shadow_pack)

    _write_json(output_root / "04_metrics_summary.json", metrics_dict)
    _write_json(
        output_root / "05_candidate_diff_report.json",
        {"candidate_diff_rows": differential_dict["candidate_diff_rows"]},
    )
    _write_json(output_root / "06_blocker_diff_report.json", differential_dict["blocker_diff"])
    _write_json(output_root / "07_economics_diff_report.json", differential_dict["economics_diff"])
    _write_json(output_root / "08_side_split_report.json", differential_dict["side_split"])
    _write_json(output_root / "09_put_leg_focus_report.json", differential_dict["put_leg_focus"])
    _write_json(output_root / "11_differential_report.json", differential_dict["differential_report"])
    _write_json(output_root / "shadow_override_flattened.json", override_dict)
    _write_json(output_root / "profile_snapshot.json", profile)

    verdict_text = _build_operator_verdict(metrics_dict, differential_dict)
    (output_root / "12_operator_verdict.txt").write_text(verdict_text, encoding="utf-8")

    comparison_summary_written = False
    if args.baseline_run_dir and args.shadow_run_dir:
        _write_comparison_summary_artifacts(
            baseline_run_dir=Path(args.baseline_run_dir).expanduser().resolve(),
            shadow_run_dir=Path(args.shadow_run_dir).expanduser().resolve(),
            output_root=output_root,
            operator_verdict=_extract_decision_label(verdict_text),
            narration="Auto-generated by replay_compare.py from baseline/shadow run summaries",
            comparison_id=args.comparison_id,
        )
        comparison_summary_written = True

    print("output_root", str(output_root))
    print("shadow_override_id", shadow_pack.override_pack_id)
    print("metrics", json.dumps(metrics_dict, sort_keys=True))
    print("comparison_summary_written", comparison_summary_written)
    print("verdict")
    print(verdict_text)

    return 0


def _parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Replay locked-vs-shadow comparison CLI")
    parser.add_argument("--profile", required=True, help="Path to replay comparison profile YAML")
    parser.add_argument("--shadow-override", required=True, help="Path to shadow override YAML")
    parser.add_argument("--baseline-frames", required=True, help="Path to baseline frames JSON")
    parser.add_argument("--shadow-frames", required=True, help="Path to shadow frames JSON")
    parser.add_argument("--output-root", required=True, help="Directory for output artifacts")

    parser.add_argument(
        "--baseline-run-dir",
        default=None,
        help="Optional replay baseline run directory containing artifacts/10_run_summary.json",
    )
    parser.add_argument(
        "--shadow-run-dir",
        default=None,
        help="Optional replay shadow run directory containing artifacts/10_run_summary.json",
    )
    parser.add_argument(
        "--comparison-id",
        default=None,
        help="Optional explicit comparison id for 20/21 comparison summary artifacts",
    )

    return parser.parse_args()


def _load_yaml_file(path: str) -> dict[str, Any]:
    source = Path(path).expanduser().resolve()
    if not source.exists():
        raise ReplayCompareCliError(f"profile file not found: {source}")
    with source.open("r", encoding="utf-8") as fh:
        data = yaml.safe_load(fh)
    if not isinstance(data, dict):
        raise ReplayCompareCliError(f"profile root must be a mapping: {source}")
    return data


def _load_json_list(path: str, *, label: str) -> list[dict[str, Any]]:
    source = Path(path).expanduser().resolve()
    if not source.exists():
        raise ReplayCompareCliError(f"{label} file not found: {source}")
    with source.open("r", encoding="utf-8") as fh:
        data = json.load(fh)
    if not isinstance(data, list):
        raise ReplayCompareCliError(f"{label} root must be a list: {source}")

    normalized: list[dict[str, Any]] = []
    for idx, item in enumerate(data):
        if not isinstance(item, dict):
            raise ReplayCompareCliError(f"{label}[{idx}] must be an object")
        normalized.append(item)
    return normalized


def _write_json(path: Path, payload: Any) -> None:
    path.write_text(
        json.dumps(payload, indent=2, sort_keys=True, ensure_ascii=False) + "\n",
        encoding="utf-8",
    )


def _extract_decision_label(verdict_text: str) -> str:
    for line in verdict_text.splitlines():
        if line.startswith("decision="):
            return line.split("=", 1)[1].strip()
    return "comparison_completed"


def _write_comparison_summary_artifacts(
    *,
    baseline_run_dir: Path,
    shadow_run_dir: Path,
    output_root: Path,
    operator_verdict: str,
    narration: str,
    comparison_id: str | None,
) -> None:
    builder = PROJECT_ROOT / "bin" / "replay_build_comparison_summary.py"
    if not builder.exists():
        raise ReplayCompareCliError(f"comparison summary builder not found: {builder}")

    cmd = [
        sys.executable,
        str(builder),
        "--baseline-run-dir",
        str(baseline_run_dir),
        "--shadow-run-dir",
        str(shadow_run_dir),
        "--output-dir",
        str(output_root),
        "--operator-verdict",
        operator_verdict,
        "--narration",
        narration,
    ]
    if comparison_id:
        cmd.extend(["--comparison-id", comparison_id])

    result = subprocess.run(
        cmd,
        cwd=str(PROJECT_ROOT),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        raise ReplayCompareCliError(
            "comparison summary builder failed:\n"
            f"stdout:\n{result.stdout}\n"
            f"stderr:\n{result.stderr}"
        )


def _build_operator_verdict(
    metrics_dict: dict[str, Any],
    differential_dict: dict[str, Any],
) -> str:
    checks = differential_dict["differential_report"]["expected_signal_checks"]

    promote_ready = (
        metrics_dict["shadow_put_candidate_count"] > metrics_dict["baseline_put_candidate_count"]
        and metrics_dict["ambiguity_rate_shadow"] <= 0.25
        and checks["regime_improved"]
        and checks["economics_improved"]
        and checks["reward_cost_fail_reduced"]
        and checks["put_focus_preserved"]
        and metrics_dict["frame_alignment_mismatch_count"] == 0
    )

    lines = [
        "REPLAY OPERATOR VERDICT",
        "",
        f"shadow_put_candidate_gain={metrics_dict['shadow_put_candidate_count'] - metrics_dict['baseline_put_candidate_count']}",
        f"newly_admitted_shadow_frames={metrics_dict['newly_admitted_shadow_frames']}",
        f"ambiguity_rate_shadow={metrics_dict['ambiguity_rate_shadow']}",
        f"frame_alignment_mismatch_count={metrics_dict['frame_alignment_mismatch_count']}",
        f"regime_improved={checks['regime_improved']}",
        f"economics_improved={checks['economics_improved']}",
        f"reward_cost_fail_reduced={checks['reward_cost_fail_reduced']}",
        f"put_focus_preserved={checks['put_focus_preserved']}",
        "",
    ]

    if promote_ready:
        lines.append("decision=shadow_candidate_promotable_for_broader_replay")
    else:
        lines.append("decision=continue_shadow_evidence_only")

    lines.append("note=test_not_contract_change")
    lines.append("note=replay_result_not_production_truth")
    return "\n".join(lines) + "\n"


if __name__ == "__main__":
    raise SystemExit(main())
