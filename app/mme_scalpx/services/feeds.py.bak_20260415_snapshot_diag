# Normalizer
# =============================================================================


class TickNormalizer:
    def __init__(
        self, *, config: FeedConfig, logger: logging.Logger | None = None
    ) -> None:
        self._cfg = config
        self._log = logger or LOGGER.getChild("TickNormalizer")

    def normalize(
        self,
        *,
        raw: BrokerRawTick,
        approved: ApprovedInstrument,
        cache_entry: QuoteCacheEntry,
        now_ns: int,
    ) -> CanonicalTickEvent:
        payload = dict(raw.payload)
        ltp = _safe_float(
            payload.get("ltp", payload.get("last_price", payload.get("LTP"))),
            math.nan,
        )
        bid = _safe_float(
            payload.get("best_bid", payload.get("bid", payload.get("bbid"))),
            math.nan,
        )
        ask = _safe_float(
            payload.get("best_ask", payload.get("ask", payload.get("bask"))),
            math.nan,
        )
        bid_qty = _safe_int(
            payload.get(
                "best_bid_qty", payload.get("bid_qty", payload.get("bbid_qty"))
            ),
            0,
        )
        ask_qty = _safe_int(
            payload.get(
                "best_ask_qty", payload.get("ask_qty", payload.get("bask_qty"))
            ),
            0,
        )

        ts_exchange_ns = self._extract_exchange_ts_ns(payload)
        ts_event_ns = ts_exchange_ns or raw.recv_ts_ns

        bid, ask, bid_qty, ask_qty, incomplete_quote = self._merge_quote(
            bid=bid,
            ask=ask,
            bid_qty=bid_qty,
            ask_qty=ask_qty,
            cache_entry=cache_entry,
        )

        validity = TickValidity.OK
        reason = "ok"

        if math.isnan(ltp):
            validity = TickValidity.MISSING_LTP
            reason = "ltp_missing"
        elif ltp <= 0.0:
            validity = TickValidity.NON_POSITIVE_LTP
            reason = "ltp_non_positive"
        elif bid_qty < 0 or ask_qty < 0:
            validity = TickValidity.NEGATIVE_QUANTITY
            reason = "negative_qty"
        elif incomplete_quote:
            validity = TickValidity.INCOMPLETE_QUOTE
            reason = "quote_incomplete"

        tick_size = float(approved.tick_size)
        if tick_size <= 0.0:
            validity = TickValidity.BAD_TICK_SIZE
            reason = "tick_size_non_positive"

        spread = 0.0
        spread_ticks = 0.0
        mid = 0.0
        if (
            not math.isnan(bid)
            and not math.isnan(ask)
            and bid > 0.0
            and ask > 0.0
        ):
            if ask < bid:
                validity = TickValidity.NON_POSITIVE_SPREAD
                reason = "ask_below_bid"
            spread = max(ask - bid, 0.0)
            spread_ticks = spread / tick_size if tick_size > 0.0 else 0.0
            mid = (bid + ask) / 2.0

        if validity == TickValidity.OK and not self._passes_anomaly_clamp(
            cache_entry=cache_entry, ltp=ltp, tick_size=tick_size
        ):
            validity = TickValidity.ANOMALY_CLAMPED
            reason = "ltp_anomaly_clamped"

        age_ms = max(int((now_ns - ts_event_ns) / 1_000_000), 0)
        if validity == TickValidity.OK and age_ms > self._cfg.member_stale_after_ms:
            validity = TickValidity.STALE
            reason = "tick_stale_on_arrival"

        strike = None
        if approved.strike is not None:
            try:
                strike = float(approved.strike)
            except Exception:
                strike = None

        return CanonicalTickEvent(
            role=approved.role,
            provider=raw.provider,
            instrument_token=approved.instrument_token,
            trading_symbol=approved.trading_symbol,
            ts_event_ns=ts_event_ns,
            ts_exchange_ns=ts_exchange_ns,
            ts_recv_ns=raw.recv_ts_ns,
            ltp=ltp,
            best_bid=bid,
            best_ask=ask,
            bid_qty_5=bid_qty,
            ask_qty_5=ask_qty,
            tick_size=tick_size,
            lot_size=approved.lot_size,
            strike=strike,
            spread=spread,
            spread_ticks=spread_ticks,
            mid=mid,
            age_ms=age_ms,
            validity=validity,
            validity_reason=reason,
        )

    @staticmethod
    def _extract_exchange_ts_ns(payload: Mapping[str, Any]) -> int | None:
        raw = (
            payload.get("exchange_ts_ns")
            or payload.get("exch_ts_ns")
            or payload.get("ts_ns")
            or payload.get("exchange_ts")
            or payload.get("exch_ts")
            or payload.get("ts")
        )
        if raw is None:
            return None
        val = _safe_int(raw, 0)
        if val <= 0:
            return None
        if val < 10_000_000_000:
            return val * 1_000_000_000
        if val < 10_000_000_000_000:
            return val * 1_000_000
        if val < 10_000_000_000_000_000:
            return val * 1_000
        return val

    @staticmethod
    def _merge_quote(
        *,
        bid: float,
        ask: float,
        bid_qty: int,
        ask_qty: int,
        cache_entry: QuoteCacheEntry,
    ) -> tuple[float, float, int, int, bool]:
        out_bid = bid if bid > 0.0 and not math.isnan(bid) else cache_entry.best_bid
        out_ask = ask if ask > 0.0 and not math.isnan(ask) else cache_entry.best_ask
        out_bq = bid_qty if bid_qty > 0 else cache_entry.bid_qty_5
        out_aq = ask_qty if ask_qty > 0 else cache_entry.ask_qty_5
        incomplete = (
            math.isnan(out_bid)
            or math.isnan(out_ask)
            or out_bid <= 0.0
            or out_ask <= 0.0
        )
        return out_bid, out_ask, out_bq, out_aq, incomplete

    def _passes_anomaly_clamp(
        self, *, cache_entry: QuoteCacheEntry, ltp: float, tick_size: float
    ) -> bool:
        dq = cache_entry.anomaly_window
        if dq.maxlen is None or dq.maxlen != self._cfg.anomaly_window:
            dq = deque(dq, maxlen=self._cfg.anomaly_window)
            cache_entry.anomaly_window = dq
        dq.append(ltp)
        if len(dq) < self._cfg.anomaly_min_samples:
            return True
        median = sorted(dq)[len(dq) // 2]
        return abs(ltp - median) <= (
            self._cfg.anomaly_median_ticks * max(tick_size, 1e-9)
        )


# =============================================================================
# Snapshot assembly helpers
# =============================================================================


class SnapshotAssembler:
    def __init__(
        self, *, config: FeedConfig, logger: logging.Logger | None = None
    ) -> None:
        self._cfg = config
        self._log = logger or LOGGER.getChild("SnapshotAssembler")

    def build_frame(
        self,
        *,
        universe: ActiveUniverse,
        cache_by_token: Mapping[str, QuoteCacheEntry],
        now_ns: int,
    ) -> SnapshotFrame:
        ins_by_role = universe.instrument_by_role()
        future = self._member_from_cache(
            ins_by_role.get(InstrumentRole.FUTURES), cache_by_token, now_ns
        )
        ce_atm = self._member_from_cache(
            ins_by_role.get(InstrumentRole.CE_ATM), cache_by_token, now_ns
        )
        ce_atm1 = self._member_from_cache(
            ins_by_role.get(InstrumentRole.CE_ATM1), cache_by_token, now_ns
        )
        pe_atm = self._member_from_cache(
            ins_by_role.get(InstrumentRole.PE_ATM), cache_by_token, now_ns
        )
        pe_atm1 = self._member_from_cache(
            ins_by_role.get(InstrumentRole.PE_ATM1), cache_by_token, now_ns
        )

        missing = [
            role_name
            for role_name, member in (
                ("future", future),
                ("ce_atm", ce_atm),
                ("ce_atm1", ce_atm1),
                ("pe_atm", pe_atm),
                ("pe_atm1", pe_atm1),
            )
            if member is None
        ]
        if missing:
            return SnapshotFrame(
                frame_id=f"frame-{now_ns}",
                selection_version=universe.selection_version,
                ts_frame_ns=now_ns,
                ts_min_member_ns=0,
                ts_max_member_ns=0,
                ts_span_ms=0,
                validity=SnapshotValidity.INCOMPLETE,
                validity_reason=f"missing_members:{','.join(missing)}",
                sync_ok=False,
                stale_mask=tuple(),
                future=future,
                ce_atm=ce_atm,
                ce_atm1=ce_atm1,
                pe_atm=pe_atm,
                pe_atm1=pe_atm1,
            )

        assert (
            future is not None
            and ce_atm is not None
            and ce_atm1 is not None
            and pe_atm is not None
            and pe_atm1 is not None
        )

        members = [future, ce_atm, ce_atm1, pe_atm, pe_atm1]
        invalid_members = [
            _stream_enum_value(m.role) for m in members if m.validity != TickValidity.OK
        ]
        stale_members = [
            _stream_enum_value(m.role)
            for m in members
            if m.age_ms > self._cfg.member_stale_after_ms
        ]
        member_ts = [m.ts_event_ns for m in members]
        ts_min = min(member_ts)
        ts_max = max(member_ts)
        span_ms = int((ts_max - ts_min) / 1_000_000)
        sync_ok = span_ms <= self._cfg.snapshot_sync_tolerance_ms

        validity = SnapshotValidity.OK
        reason = "ok"
        if invalid_members:
            validity = SnapshotValidity.INVALID_MEMBER
            reason = f"invalid_members:{','.join(invalid_members)}"
        elif stale_members:
            validity = SnapshotValidity.STALE
            reason = f"stale_members:{','.join(stale_members)}"
        elif not sync_ok:
            validity = SnapshotValidity.UNSYNCED
            reason = f"unsynced:span_ms={span_ms}"

        return SnapshotFrame(
            frame_id=f"frame-{now_ns}",
            selection_version=universe.selection_version,
            ts_frame_ns=now_ns,
            ts_min_member_ns=ts_min,
            ts_max_member_ns=ts_max,
            ts_span_ms=span_ms,
            validity=validity,
            validity_reason=reason,
            sync_ok=sync_ok,
            stale_mask=tuple(stale_members),
            future=future,
            ce_atm=ce_atm,
            ce_atm1=ce_atm1,
            pe_atm=pe_atm,
            pe_atm1=pe_atm1,
        )

    @staticmethod
    def _member_from_cache(
        approved: ApprovedInstrument | None,
        cache_by_token: Mapping[str, QuoteCacheEntry],
        now_ns: int,
    ) -> SnapshotMember | None:
        if approved is None:
            return None
        cache = cache_by_token.get(approved.instrument_token)
        if cache is None or cache.last_event_ns <= 0:
            return None
        strike = None
        if approved.strike is not None:
            try:
                strike = float(approved.strike)
            except Exception:
                strike = None
        age_ms = cache.age_ms(now_ns=now_ns)
        validity = (
            cache.last_validity if age_ms <= FEED_STALE_MS else TickValidity.STALE
        )
        spread = 0.0
        spread_ticks = 0.0
        if cache.best_ask > 0.0 and cache.best_bid > 0.0:
            spread = max(cache.best_ask - cache.best_bid, 0.0)
            spread_ticks = (
                spread / float(approved.tick_size)
                if float(approved.tick_size) > 0.0
                else 0.0
            )
        return SnapshotMember(
            role=approved.role,
            instrument_token=approved.instrument_token,
            trading_symbol=approved.trading_symbol,
            ts_event_ns=cache.last_event_ns,
            ltp=cache.ltp,
            best_bid=cache.best_bid,
            best_ask=cache.best_ask,
            bid_qty_5=cache.bid_qty_5,
            ask_qty_5=cache.ask_qty_5,
            spread=spread,
            spread_ticks=spread_ticks,
            age_ms=age_ms,
            tick_size=float(approved.tick_size),
            lot_size=approved.lot_size,
            strike=strike,
            validity=validity,
        )


# =============================================================================
# Feed service
# =============================================================================


class FeedService:
    REQUIRED_ROLE_COUNT = 5

    def __init__(
        self,
        *,
        universe: ActiveUniverse,
        config: FeedConfig,
        redis_client: Any,
        clock: ClockProtocol,
        instance_id: str,
        logger: logging.Logger | None = None,
    ) -> None:
        self._cfg = config
        self._clock = clock
        self._log = logger or LOGGER.getChild(config.service_name)
        self._redis = redis_client
        self._instance_id = instance_id

        self._universe = universe
        self._token_to_approved = universe.instrument_by_token()
        self._provider = str(config.provider)

        if len(self._token_to_approved) != self.REQUIRED_ROLE_COUNT:
            raise FeedConfigError(
                f"active universe must contain exactly {self.REQUIRED_ROLE_COUNT} contracts; got {len(self._token_to_approved)}"
            )

        self._cache_by_token: dict[str, QuoteCacheEntry] = {
            token: QuoteCacheEntry(
                approved=approved, anomaly_window=deque(maxlen=self._cfg.anomaly_window)
            )
            for token, approved in self._token_to_approved.items()
        }
        self._normalizer = TickNormalizer(config=config, logger=self._log)
        self._assembler = SnapshotAssembler(config=config, logger=self._log)
        self._counters = FeedCounters()
        self._last_heartbeat_ns = 0
        self._last_state_publish_ns = 0
        self._last_lock_refresh_ns = 0
        self._last_snapshot: SnapshotFrame | None = None
        self._last_tick_recv_ns = 0
        self._current_health_status = N.HEALTH_STATUS_OK
        self._current_health_detail = "booting"

    def start(self) -> None:
        now_ns = self._clock.wall_time_ns()
        self._last_lock_refresh_ns = now_ns
        self._set_health(
            status=N.HEALTH_STATUS_OK,
            detail="service_started",
        )
        self._publish_health_event(event="service_started")

    def stop(self) -> None:
        self._set_health(status=N.HEALTH_STATUS_WARN, detail="service_stopping")
        self._publish_health_event(event="service_stopping")

    def run_housekeeping_once(self) -> None:
        now_ns = self._clock.wall_time_ns()

        self._update_no_data_health(now_ns=now_ns)

        if (now_ns - self._last_heartbeat_ns) >= (
            self._cfg.heartbeat_interval_ms * 1_000_000
        ):
            self._publish_heartbeat(now_ns=now_ns)
            self._last_heartbeat_ns = now_ns

        if (now_ns - self._last_state_publish_ns) >= (
            self._cfg.state_publish_interval_ms * 1_000_000
        ):
            self._publish_state(now_ns=now_ns)
            self._last_state_publish_ns = now_ns

    def refresh_lock_if_due(self) -> None:
        now_ns = self._clock.wall_time_ns()
        if (now_ns - self._last_lock_refresh_ns) < (
            self._cfg.lock_refresh_ms * 1_000_000
        ):
            return
        ok = RX.refresh_lock(
            N.KEY_LOCK_FEEDS,
            self._instance_id,
            ttl_ms=self._cfg.lock_ttl_ms,
            client=self._redis,
        )
        if not ok:
            raise FeedStartupError("feeds singleton lock refresh failed")
        self._last_lock_refresh_ns = now_ns

    def handle_broker_payload(
        self,
        *,
        instrument_token: str,
        payload: Mapping[str, Any],
        provider: str | None = None,
        recv_ts_ns: int | None = None,
    ) -> tuple[CanonicalTickEvent | None, SnapshotFrame | None]:
        raw = BrokerRawTick.from_payload(
            instrument_token=instrument_token,
            provider=provider or self._provider,
            payload=payload,
            recv_ts_ns=recv_ts_ns
            if recv_ts_ns is not None
            else self._clock.wall_time_ns(),
        )
        return self.handle_raw_tick(raw)

    def handle_raw_tick(
        self, raw: BrokerRawTick
    ) -> tuple[CanonicalTickEvent | None, SnapshotFrame | None]:
        self._counters.ticks_received_total += 1
        self._last_tick_recv_ns = max(self._last_tick_recv_ns, raw.recv_ts_ns)

        now_ns = self._clock.wall_time_ns()
        approved = self._token_to_approved.get(raw.instrument_token)
        if approved is None:
            self._counters.ticks_rejected_total += 1
            return None, None

        cache_entry = self._cache_by_token[raw.instrument_token]
        tick = self._normalizer.normalize(
            raw=raw,
            approved=approved,
            cache_entry=cache_entry,
            now_ns=now_ns,
        )

        if tick.validity == TickValidity.OK:
            self._accept_into_cache(tick=tick, cache_entry=cache_entry)
            self._counters.ticks_accepted_total += 1
            self._set_health(status=N.HEALTH_STATUS_OK, detail="ticks_flowing")
        else:
            cache_entry.last_validity = tick.validity
            cache_entry.last_validity_reason = tick.validity_reason
            self._counters.ticks_rejected_total += 1

        if self._cfg.publish_every_tick:
            self._publish_tick(tick)

        frame = self._assembler.build_frame(
            universe=self._universe,
            cache_by_token=self._cache_by_token,
            now_ns=now_ns,
        )

        should_publish_snapshot = (
            not self._cfg.publish_snapshots_only_when_complete
            or frame.validity == SnapshotValidity.OK
        )
        if should_publish_snapshot:
            self._publish_snapshot(frame)
            self._last_snapshot = frame
            self._counters.snapshots_published_total += 1

        if self._cfg.publish_state_on_every_snapshot:
            self._publish_state(now_ns=now_ns)

        return tick, frame

    def _accept_into_cache(
        self, *, tick: CanonicalTickEvent, cache_entry: QuoteCacheEntry
    ) -> None:
        cache_entry.last_event_ns = int(tick.ts_event_ns)
        cache_entry.last_exchange_ns = int(tick.ts_exchange_ns or 0)
        cache_entry.ltp = float(tick.ltp)
        cache_entry.best_bid = float(tick.best_bid)
        cache_entry.best_ask = float(tick.best_ask)
        cache_entry.bid_qty_5 = int(tick.bid_qty_5)
        cache_entry.ask_qty_5 = int(tick.ask_qty_5)
        cache_entry.seen_count += 1
        cache_entry.last_validity = tick.validity
        cache_entry.last_validity_reason = tick.validity_reason

    def _publish_tick(self, tick: CanonicalTickEvent) -> None:
        RX.xadd_fields(tick.stream_name(), tick.to_dict(), client=self._redis)

    def _publish_snapshot(self, frame: SnapshotFrame) -> None:
        RX.write_hash_fields(
            N.HASH_STATE_SNAPSHOT_MME_FUT,
            self._snapshot_fut_hash_payload(frame),
            client=self._redis,
        )
        RX.write_hash_fields(
            N.HASH_STATE_SNAPSHOT_MME_OPT_SELECTED,
            self._snapshot_opt_hash_payload(frame),
            client=self._redis,
        )

    def _publish_state(self, *, now_ns: int) -> None:
        seen_tokens = sum(
            1 for cache in self._cache_by_token.values() if cache.last_event_ns > 0
        )
        state = FeedState(
            selection_version=self._universe.selection_version,
            provider=self._provider,
            ts_ns=now_ns,
            approved_tokens=len(self._token_to_approved),
            seen_tokens=seen_tokens,
            latest_snapshot_validity=""
            if self._last_snapshot is None
            else _stream_enum_value(self._last_snapshot.validity),
            latest_snapshot_reason=""
            if self._last_snapshot is None
            else str(self._last_snapshot.validity_reason),
            last_frame_id=None if self._last_snapshot is None else self._last_snapshot.frame_id,
            last_frame_ts_ns=None
            if self._last_snapshot is None
            else int(self._last_snapshot.ts_frame_ns),
            ticks_received_total=self._counters.ticks_received_total,
            ticks_accepted_total=self._counters.ticks_accepted_total,
            ticks_rejected_total=self._counters.ticks_rejected_total,
            snapshots_published_total=self._counters.snapshots_published_total,
        )
        payload = {f"feeds_{k}": v for k, v in state.to_dict().items()}
        RX.write_hash_fields(N.HASH_STATE_RUNTIME, payload, client=self._redis)
        self._counters.states_published_total += 1

    def _publish_heartbeat(self, *, now_ns: int) -> None:
        RX.write_heartbeat(
            N.KEY_HEALTH_FEEDS,
            service=N.SERVICE_FEEDS,
            instance_id=self._instance_id,
            status=self._current_health_status,
            ts_event_ns=now_ns,
            ttl_ms=self._cfg.heartbeat_interval_ms * 3,
            client=self._redis,
        )
        self._counters.heartbeats_published_total += 1

    def _publish_health_event(self, *, event: str) -> None:
        now_ns = self._clock.wall_time_ns()
        RX.xadd_fields(
            N.STREAM_SYSTEM_HEALTH,
            {
                "service_name": N.SERVICE_FEEDS,
                "instance_id": self._instance_id,
                "status": self._current_health_status,
                "event": event,
                "detail": self._current_health_detail,
                "ts_ns": str(now_ns),
                "provider": self._provider,
                "selection_version": self._universe.selection_version,
                "ticks_received_total": self._counters.ticks_received_total,
                "ticks_accepted_total": self._counters.ticks_accepted_total,
                "ticks_rejected_total": self._counters.ticks_rejected_total,
                "snapshots_published_total": self._counters.snapshots_published_total,
            },
            maxlen_approx=HEALTH_STREAM_MAXLEN,
            client=self._redis,
        )

    def _publish_error_event(self, *, event: str, detail: str) -> None:
        now_ns = self._clock.wall_time_ns()
        RX.xadd_fields(
            N.STREAM_SYSTEM_ERRORS,
            {
                "service_name": N.SERVICE_FEEDS,
                "instance_id": self._instance_id,
                "error_type": event,
                "detail": detail,
                "ts_ns": str(now_ns),
                "provider": self._provider,
                "selection_version": self._universe.selection_version,
            },
            maxlen_approx=ERROR_STREAM_MAXLEN,
            client=self._redis,
        )

    def _set_health(self, *, status: str, detail: str) -> None:
        self._current_health_status = status
        self._current_health_detail = detail

    def _update_no_data_health(self, *, now_ns: int) -> None:
        if self._last_tick_recv_ns <= 0:
            self._set_health(status=N.HEALTH_STATUS_WARN, detail="waiting_for_first_tick")
            return

        age_ms = max(int((now_ns - self._last_tick_recv_ns) / 1_000_000), 0)
        if age_ms >= self._cfg.no_data_error_after_ms:
            self._set_health(status=N.HEALTH_STATUS_ERROR, detail="tick_flow_dead")
        elif age_ms >= self._cfg.no_data_warn_after_ms:
            self._set_health(status=N.HEALTH_STATUS_WARN, detail="tick_flow_stale")
        elif self._current_health_status != N.HEALTH_STATUS_OK:
            self._set_health(status=N.HEALTH_STATUS_OK, detail="ticks_flowing")

    @staticmethod
    def _snapshot_member_to_dict(member: SnapshotMember | None) -> Any:
        if member is None:
            return None
        if hasattr(member, "to_dict"):
            return member.to_dict()
        return asdict(member)

    def _snapshot_fut_hash_payload(self, frame: SnapshotFrame) -> dict[str, Any]:
        return {
            "frame_id": frame.frame_id,
            "selection_version": frame.selection_version,
            "ts_frame_ns": frame.ts_frame_ns,
            "validity": _stream_enum_value(frame.validity),
            "validity_reason": frame.validity_reason,
            "sync_ok": "1" if frame.sync_ok else "0",
            "ts_span_ms": frame.ts_span_ms,
            "stale_mask_json": _json_dumps([_stream_enum_value(x) for x in frame.stale_mask]),
            "future_json": _json_dumps(self._snapshot_member_to_dict(frame.future)),
        }

    def _snapshot_opt_hash_payload(self, frame: SnapshotFrame) -> dict[str, Any]:
        return {
            "frame_id": frame.frame_id,
            "selection_version": frame.selection_version,
            "ts_frame_ns": frame.ts_frame_ns,
            "validity": _stream_enum_value(frame.validity),
            "validity_reason": frame.validity_reason,
            "sync_ok": "1" if frame.sync_ok else "0",
            "ts_span_ms": frame.ts_span_ms,
            "stale_mask_json": _json_dumps([_stream_enum_value(x) for x in frame.stale_mask]),
            "ce_atm_json": _json_dumps(self._snapshot_member_to_dict(frame.ce_atm)),
            "ce_atm1_json": _json_dumps(self._snapshot_member_to_dict(frame.ce_atm1)),
            "pe_atm_json": _json_dumps(self._snapshot_member_to_dict(frame.pe_atm)),
            "pe_atm1_json": _json_dumps(self._snapshot_member_to_dict(frame.pe_atm1)),
        }


# =============================================================================
# Canonical entrypoint
# =============================================================================


def run(context: Any) -> int:
    _validate_name_surface_or_die()

    settings = context.settings
    redis_runtime = context.redis
    redis_client = (
        redis_runtime.sync if hasattr(redis_runtime, "sync") else redis_runtime
    )
    shutdown = context.shutdown
    clock = context.clock
    instance_id = context.instance_id

    if clock is None or not hasattr(clock, "wall_time_ns"):
        raise FeedStartupError("context.clock with wall_time_ns() is required")
    if shutdown is None or not hasattr(shutdown, "is_set") or not hasattr(shutdown, "wait"):
        raise FeedStartupError("context.shutdown with is_set()/wait() is required")
    if not instance_id:
        raise FeedStartupError("context.instance_id is required")

    runtime_set = getattr(context, "runtime_instruments", None)
    if runtime_set is None:
        runtime_set = getattr(context, "instrument_set", None)
    if runtime_set is None:
        raise FeedStartupError(
            "context must provide runtime_instruments / instrument_set for feeds service"
        )
    required_attrs = (
        "selection_version",
        "underlying_symbol",
        "underlying_reference",
        "option_expiry",
        "strike_step",
        "current_future",
        "ce_atm",
        "ce_atm1",
        "pe_atm",
        "pe_atm1",
    )
    missing_runtime_attrs = [name for name in required_attrs if not hasattr(runtime_set, name)]
    if missing_runtime_attrs:
        raise FeedStartupError(
            "runtime instrument set missing required attributes: "
            + ", ".join(sorted(missing_runtime_attrs))
        )

    adapter = getattr(context, "feed_adapter", None)
    if adapter is None:
        adapter = getattr(context, "market_data_adapter", None)
    if adapter is None:
        raise FeedStartupError(
            "context must provide feed_adapter / market_data_adapter implementing poll()"
        )
    if not hasattr(adapter, "poll") or not callable(adapter.poll):
        raise FeedStartupError("feed adapter must expose callable poll()")

    if not RX.ping_redis(client=redis_client):
        raise FeedStartupError("feeds redis ping failed during startup")

    cfg = FeedConfig(
        provider=str(getattr(settings, "feed_provider", "OTHER")),
        heartbeat_interval_ms=int(
            getattr(settings, "feeds_heartbeat_interval_ms", DEFAULT_HEARTBEAT_INTERVAL_MS)
        ),
        state_publish_interval_ms=int(
            getattr(settings, "feeds_state_publish_interval_ms", DEFAULT_STATE_PUBLISH_INTERVAL_MS)
        ),
        member_stale_after_ms=int(
            getattr(settings, "feeds_member_stale_after_ms", FEED_STALE_MS)
        ),
        snapshot_sync_tolerance_ms=int(
            getattr(settings, "feeds_snapshot_sync_tolerance_ms", SYNC_WINDOW_MS)
        ),
        publish_every_tick=bool(getattr(settings, "feeds_publish_every_tick", True)),
        publish_snapshots_only_when_complete=bool(
            getattr(settings, "feeds_publish_snapshots_only_when_complete", True)
        ),
        publish_state_on_every_snapshot=bool(
            getattr(settings, "feeds_publish_state_on_every_snapshot", False)
        ),
        lock_ttl_ms=int(getattr(settings, "feeds_lock_ttl_ms", LOCK_TTL_MS)),
        lock_refresh_ms=int(getattr(settings, "feeds_lock_refresh_ms", LOCK_REFRESH_MS)),
        no_data_warn_after_ms=int(
            getattr(settings, "feeds_no_data_warn_after_ms", NO_DATA_WARN_AFTER_MS)
        ),
        no_data_error_after_ms=int(
            getattr(settings, "feeds_no_data_error_after_ms", NO_DATA_ERROR_AFTER_MS)
        ),
    )

    acquired = RX.acquire_lock(
        N.KEY_LOCK_FEEDS,
        instance_id,
        ttl_ms=cfg.lock_ttl_ms,
        client=redis_client,
    )
    if not acquired:
        raise FeedStartupError("feeds singleton lock not acquired")

    service = FeedService(
        universe=ActiveUniverse.from_runtime_set(
            runtime_set,
            generated_at_ns=int(clock.wall_time_ns()),
        ),
        config=cfg,
        redis_client=redis_client,
        clock=clock,
        instance_id=instance_id,
        logger=LOGGER,
    )
    service.start()

    poll_interval_s = (
        max(
            int(getattr(settings, "feeds_poll_interval_ms", DEFAULT_POLL_INTERVAL_MS)),
            10,
        )
        / 1000.0
    )

    try:
        while not shutdown.is_set():
            try:
                polled = adapter.poll()
                if polled is None:
                    polled = []
                for item in polled:
                    instrument_token = _safe_str(item.get("instrument_token"))
                    payload = item.get("payload")
                    if not instrument_token or not isinstance(payload, Mapping):
                        continue
                    service.handle_broker_payload(
                        instrument_token=instrument_token,
                        payload=payload,
                        provider=_safe_str(item.get("provider"))
                        or str(getattr(settings, "feed_provider", "OTHER")),
                        recv_ts_ns=_safe_int(item.get("recv_ts_ns"), int(clock.wall_time_ns())),
                    )
                service.refresh_lock_if_due()
                service.run_housekeeping_once()
            except Exception as exc:
                LOGGER.exception("feeds_service_loop_error")
                with contextlib.suppress(Exception):
                    service._set_health(
                        status=N.HEALTH_STATUS_ERROR,
                        detail=f"loop_error:{type(exc).__name__}",
                    )
                    service._publish_error_event(
                        event="feeds_service_loop_error",
                        detail=f"{type(exc).__name__}:{exc}",
                    )
            shutdown.wait(poll_interval_s)
    finally:
        service.stop()
        with contextlib.suppress(Exception):
            RX.write_heartbeat(
                N.KEY_HEALTH_FEEDS,
                service=N.SERVICE_FEEDS,
                instance_id=instance_id,
                status="STOPPED",
                ts_event_ns=int(clock.wall_time_ns()),
                ttl_ms=cfg.heartbeat_interval_ms * 3,
                client=redis_client,
            )
        with contextlib.suppress(Exception):
            RX.release_lock(
                N.KEY_LOCK_FEEDS,
                instance_id,
                client=redis_client,
            )

    LOGGER.info("feeds_service_stopped")
    return 0