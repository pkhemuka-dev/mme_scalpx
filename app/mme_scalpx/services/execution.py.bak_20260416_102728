    # ------------------------------------------------------------------
    # Error helpers
    # ------------------------------------------------------------------

    def _reject_decision(self, decision: DecisionView, reason: str) -> None:
        now_ns = self.now_ns()
        self.execution_state["last_error"] = reason
        self.execution_state["last_ack_type"] = N.ACK_REJECTED
        self.execution_state["updated_at_ns"] = now_ns
        self.execution_state["ts_ns"] = now_ns
        self._publish_ack(
            ack_type=N.ACK_REJECTED,
            decision=decision,
            reason=reason,
            broker_order=None,
        )

    def _fail_decision(self, decision: DecisionView, reason: str) -> None:
        now_ns = self.now_ns()
        self.execution_state["last_error"] = reason
        self.execution_state["last_ack_type"] = N.ACK_FAILED
        self.execution_state["updated_at_ns"] = now_ns
        self.execution_state["ts_ns"] = now_ns
        self._publish_ack(
            ack_type=N.ACK_FAILED,
            decision=decision,
            reason=reason,
            broker_order=None,
        )
        self._publish_system_error(event="decision_failed", details=reason)

    def _record_exception(
        self,
        where: str,
        exc: Exception,
        extra: Mapping[str, Any] | None = None,
    ) -> None:
        detail = {
            "where": where,
            "error_type": type(exc).__name__,
            "error": str(exc),
        }
        if extra:
            detail.update(dict(extra))

        now_ns = self.now_ns()
        self.execution_state["last_error"] = f"{where}:{type(exc).__name__}:{exc}"
        self.execution_state["updated_at_ns"] = now_ns
        self.execution_state["ts_ns"] = now_ns

        with contextlib.suppress(Exception):
            RX.write_hash_fields(
                N.HASH_STATE_EXECUTION,
                self.execution_state,
                client=self.redis,
            )

        self._publish_system_error(
            event="EXECUTION_EXCEPTION",
            details=str(detail),
        )
        self.log.exception("execution exception where=%s", where)


def run(context: Any) -> int | None:
    _validate_name_surface_or_die()

    redis_runtime = getattr(context, "redis", None)
    broker = getattr(context, "broker", None)
    clock = getattr(context, "clock", None)
    shutdown = getattr(context, "shutdown", None)
    instance_id = getattr(context, "instance_id", None)
    consumer_name = getattr(context, "consumer_name", None)

    if redis_runtime is None:
        raise ExecutionConfigError("run(context) requires context.redis")
    if broker is None:
        raise ExecutionConfigError("run(context) requires context.broker")
    if clock is None:
        raise ExecutionConfigError("run(context) requires context.clock")
    if shutdown is None:
        raise ExecutionConfigError("run(context) requires context.shutdown")
    if not instance_id:
        raise ExecutionConfigError("run(context) requires context.instance_id")
    if not consumer_name:
        raise ExecutionConfigError("run(context) requires context.consumer_name")

    redis_client = redis_runtime.sync if hasattr(redis_runtime, "sync") else redis_runtime

    service = ExecutionService(
        redis_client=redis_client,
        broker=broker,
        clock=clock,
        shutdown=shutdown,
        instance_id=str(instance_id),
        consumer_name=str(consumer_name),
        logger=LOGGER,
    )
    return service.start()