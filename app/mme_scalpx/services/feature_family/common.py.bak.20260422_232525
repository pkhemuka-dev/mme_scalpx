def derive_provider_ready_classic(
    *,
    active_futures_provider_id: str | None,
    active_selected_option_provider_id: str | None,
    active_option_context_provider_id: str | None = None,
    futures_provider_status: str | None,
    selected_option_provider_status: str | None,
    option_context_provider_status: str | None = None,
) -> bool:
    """
    Classic-family provider readiness helper.

    The classic four are Dhan-enhanced but degraded-safe. Therefore:
    - active futures lane must be canonical and HEALTHY
    - active selected-option lane must be canonical and HEALTHY
    - option-context may be present and may improve the doctrine, but its
      stale/degraded/unavailable state must not by itself make the classic lane
      not ready
    """
    core_ready = all(
        (
            active_futures_provider_id in C.ALLOWED_PROVIDER_IDS,
            active_selected_option_provider_id in C.ALLOWED_PROVIDER_IDS,
            futures_provider_status == N.PROVIDER_STATUS_HEALTHY,
            selected_option_provider_status == N.PROVIDER_STATUS_HEALTHY,
        )
    )
    if not core_ready:
        return False

    if active_option_context_provider_id is not None:
        _require(
            active_option_context_provider_id in C.ALLOWED_PROVIDER_IDS,
            "active_option_context_provider_id must be a canonical provider id",
        )
    if option_context_provider_status is not None:
        _require(
            option_context_provider_status in C.ALLOWED_PROVIDER_STATUSES,
            "option_context_provider_status must be a canonical provider status",
        )

    return True


def derive_provider_ready_miso(
    *,
    dhan_futures_provider_status: str | None,
    dhan_selected_option_provider_status: str | None,
    dhan_option_context_status: str | None,
    acceptable_statuses: tuple[str, ...] = (
        N.PROVIDER_STATUS_HEALTHY,
        N.PROVIDER_STATUS_DEGRADED,
    ),
) -> bool:
    """
    MISO provider/runtime readiness helper.

    This models Dhan-lane runtime readiness, not final entry admissibility.
    By default, HEALTHY and DEGRADED are acceptable runtime states here.
    """
    _require(
        isinstance(acceptable_statuses, tuple) and len(acceptable_statuses) > 0,
        "acceptable_statuses must be a non-empty tuple",
    )
    for status in acceptable_statuses:
        _require(
            status in C.ALLOWED_PROVIDER_STATUSES,
            f"invalid acceptable provider status: {status!r}",
        )

    return all(
        (
            dhan_futures_provider_status in acceptable_statuses,
            dhan_selected_option_provider_status in acceptable_statuses,
            dhan_option_context_status in acceptable_statuses,
        )
    )


def derive_selected_option_present(
    *,
    selected_side: str | None,
    selected_option_ltp: float | None,
    selected_option_depth_total: float | None = None,
) -> bool:
    return (
        selected_side in OPTION_SIDE_IDS
        and selected_option_ltp is not None
        and (selected_option_depth_total is None or selected_option_depth_total > 0.0)
    )


def derive_common_premium_floor_ok(
    *,
    selected_option_ltp: float | None,
    minimum_premium: float,
) -> bool:
    ltp = _normalize_optional_float(selected_option_ltp)
    floor = _normalize_optional_float(minimum_premium)
    _require(floor is not None and floor >= 0.0, "minimum_premium must be >= 0")
    return ltp is not None and ltp >= floor


def derive_depth_ok(
    *,
    depth_total: float | None,
    minimum_depth: float,
) -> bool:
    depth = _normalize_optional_float(depth_total)
    minimum = _normalize_optional_float(minimum_depth)
    _require(minimum is not None and minimum >= 0.0, "minimum_depth must be >= 0")
    return depth is not None and depth >= minimum


def derive_spread_ratio_ok(
    *,
    spread_ratio: float | None,
    maximum_spread_ratio: float,
) -> bool:
    ratio = _normalize_optional_float(spread_ratio)
    maximum = _normalize_optional_float(maximum_spread_ratio)
    _require(
        maximum is not None and maximum > 0.0,
        "maximum_spread_ratio must be > 0",
    )
    return ratio is not None and ratio <= maximum


def derive_response_efficiency_ok(
    *,
    response_efficiency: float | None,
    minimum_response_efficiency: float,
) -> bool:
    response = _normalize_optional_float(response_efficiency)
    minimum = _normalize_optional_float(minimum_response_efficiency)
    _require(
        minimum is not None,
        "minimum_response_efficiency must be provided",
    )
    return response is not None and response >= minimum


def derive_tradability_ok(
    *,
    depth_ok: bool,
    spread_ratio_ok: bool,
    response_efficiency_ok: bool,
) -> bool:
    return bool(depth_ok and spread_ratio_ok and response_efficiency_ok)


def derive_selected_option_tradability_ok(
    *,
    call_tradability_ok: bool,
    put_tradability_ok: bool,
    selected_side: str | None,
) -> bool:
    if selected_side == OPTION_SIDE_CALL:
        return call_tradability_ok
    if selected_side == OPTION_SIDE_PUT:
        return put_tradability_ok
    return False


def derive_stage_flags(
    *,
    snapshot_valid: bool,
    session_eligible: bool,
    warmup_complete: bool,
    risk_veto_active: bool,
    reconciliation_lock_active: bool,
