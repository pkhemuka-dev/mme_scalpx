def build_snapshot_block(
    *,
    valid: bool = False,
    validity: str = "UNAVAILABLE",
    sync_ok: bool = False,
    freshness_ok: bool = False,
    packet_gap_ok: bool = False,
    warmup_ok: bool = False,
    active_snapshot_ns: int | None = None,
    futures_snapshot_ns: int | None = None,
    selected_option_snapshot_ns: int | None = None,
    dhan_futures_snapshot_ns: int | None = None,
    dhan_option_snapshot_ns: int | None = None,
    max_member_age_ms: float | None = None,
    fut_opt_skew_ms: float | None = None,
    hard_packet_gap_ms: float | None = None,
    samples_seen: int = 0,
) -> dict[str, Any]:
    block = {
        "valid": _normalize_bool(valid, field_name="snapshot.valid"),
        "validity": _normalize_literal(
            validity,
            allowed=("OK", "UNAVAILABLE", "INCOMPLETE", "INVALID_MEMBER", "UNSYNCED"),
            field_name="snapshot.validity",
        ),
        "sync_ok": _normalize_bool(sync_ok, field_name="snapshot.sync_ok"),
        "freshness_ok": _normalize_bool(
            freshness_ok,
            field_name="snapshot.freshness_ok",
        ),
        "packet_gap_ok": _normalize_bool(
            packet_gap_ok,
            field_name="snapshot.packet_gap_ok",
        ),
        "warmup_ok": _normalize_bool(warmup_ok, field_name="snapshot.warmup_ok"),
        "active_snapshot_ns": _normalize_optional_int(active_snapshot_ns),
        "futures_snapshot_ns": _normalize_optional_int(futures_snapshot_ns),
        "selected_option_snapshot_ns": _normalize_optional_int(selected_option_snapshot_ns),
        "dhan_futures_snapshot_ns": _normalize_optional_int(dhan_futures_snapshot_ns),
        "dhan_option_snapshot_ns": _normalize_optional_int(dhan_option_snapshot_ns),
        "max_member_age_ms": _normalize_optional_float(max_member_age_ms),
        "fut_opt_skew_ms": _normalize_optional_float(fut_opt_skew_ms),
        "hard_packet_gap_ms": _normalize_optional_float(hard_packet_gap_ms),
        "samples_seen": _normalize_int(samples_seen, field_name="snapshot.samples_seen"),
    }
    return _validate_block(block, validator=C.validate_snapshot_block)


