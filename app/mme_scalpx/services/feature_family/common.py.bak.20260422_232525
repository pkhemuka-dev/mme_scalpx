EPSILON: Final[float] = 1e-8

OPTION_SIDE_CALL: Final[str] = N.SIDE_CALL
OPTION_SIDE_PUT: Final[str] = N.SIDE_PUT
OPTION_SIDE_IDS: Final[tuple[str, ...]] = (
    OPTION_SIDE_CALL,
    OPTION_SIDE_PUT,
)


# ============================================================================
# Exceptions
# ============================================================================


class FeatureFamilyCommonError(ValueError):
    """Raised when helper construction inputs are invalid."""


# ============================================================================
# Small internal helpers
# ============================================================================


def _require(condition: bool, message: str) -> None:
    if not condition:
        raise FeatureFamilyCommonError(message)


def _require_mapping(value: Any, *, field_name: str) -> Mapping[str, Any]:
    if not isinstance(value, Mapping):
        raise FeatureFamilyCommonError(f"{field_name} must be a mapping")
    return value


def _copy_mapping(value: Mapping[str, Any]) -> dict[str, Any]:
    return dict(value)


def _normalize_int(value: Any, *, field_name: str) -> int:
    if isinstance(value, bool) or not isinstance(value, int):
        raise FeatureFamilyCommonError(f"{field_name} must be int")
    return value


def _normalize_optional_float(value: Any) -> float | None:
    if value is None:
        return None
    if isinstance(value, bool):
        raise FeatureFamilyCommonError("bool is not a valid float input")
    if isinstance(value, (int, float)):
        result = float(value)
        if not isfinite(result):
            raise FeatureFamilyCommonError(f"non-finite float value: {value!r}")
        return result
    raise FeatureFamilyCommonError(f"expected float|int|None, got {type(value).__name__}")


def _normalize_optional_int(value: Any) -> int | None:
    if value is None:
        return None
    if isinstance(value, bool) or not isinstance(value, int):
        raise FeatureFamilyCommonError(f"expected int|None, got {type(value).__name__}")
    return value


def _normalize_optional_bool(value: Any) -> bool | None:
    if value is None:
        return None
    if not isinstance(value, bool):
        raise FeatureFamilyCommonError(f"expected bool|None, got {type(value).__name__}")
    return value


def _normalize_bool(value: Any, *, field_name: str) -> bool:
    if not isinstance(value, bool):
        raise FeatureFamilyCommonError(f"{field_name} must be bool")
    return value


def _normalize_optional_str(value: Any) -> str | None:
    if value is None:
        return None
    if not isinstance(value, str):
        raise FeatureFamilyCommonError(f"expected str|None, got {type(value).__name__}")
    text = value.strip()
    if not text:
        raise FeatureFamilyCommonError("string value must be non-empty when provided")
    return text


def _normalize_optional_literal(
    value: Any,
    *,
    allowed: tuple[str, ...],
    field_name: str,
) -> str | None:
    text = _normalize_optional_str(value)
    if text is None:
        return None
    if text not in allowed:
        raise FeatureFamilyCommonError(
            f"{field_name} must be one of {allowed!r} or None, got {text!r}"
        )
    return text


def _normalize_literal(
    value: Any,
    *,
    allowed: tuple[str, ...],
    field_name: str,
) -> str:
    text = _normalize_optional_literal(value, allowed=allowed, field_name=field_name)
    if text is None:
        raise FeatureFamilyCommonError(f"{field_name} may not be None")
    return text


def _merge_exact(
    base: Mapping[str, Any],
    overrides: Mapping[str, Any] | None = None,
    *,
    field_name: str,
) -> dict[str, Any]:
    result = _copy_mapping(base)
    if overrides is None:
        return result

    override_map = _require_mapping(overrides, field_name=field_name)
    unknown = tuple(key for key in override_map.keys() if key not in result)
    if unknown:
        raise FeatureFamilyCommonError(
            f"{field_name} contains unknown keys: {unknown!r}"
        )
    result.update(override_map)
    return result


def _validate_block(
    block: Mapping[str, Any],
    *,
    validator,
) -> dict[str, Any]:
    payload = dict(block)
    validator(payload)
    return payload


