def build_app_context(*, settings: AppSettings, clock: BaseClock) -> AppContext:
    """Build immutable process context after settings + clock are ready."""
    try:
        sync_client = redisx.build_redis_client(settings=settings)
    except Exception as exc:
        raise BootstrapError(f"failed to build sync Redis client: {exc}") from exc

    async_client: Any | None = None
    try:
        async_client = redisx.build_async_redis_client(settings=settings)
    except Exception:
        async_client = None

    return AppContext(
        settings=settings,
        redis=RedisRuntime(sync=sync_client, async_=async_client),
        clock=clock,
        node_name=socket.gethostname(),
        pid=os.getpid(),
        app_name=settings.app_name,
        env=settings.app_env,
        dependencies=get_bootstrap_dependencies(),
    )


def build_service_identity(app: AppContext, service_name: str) -> ServiceIdentity:
    service = _require_non_empty_str(service_name, field_name="service_name")
    return ServiceIdentity(
        service_name=service,
        instance_id=app.instance_name(service),
        consumer_name=app.consumer_name(service),
        node_name=app.node_name,
        pid=app.pid,
    )


def _require_service_dependencies(app: AppContext, service_name: str) -> None:
    """
    Enforce only proven service dependency requirements.

    feeds.py requires:
      - runtime_instruments / instrument_set
      - feed_adapter / market_data_adapter

    execution.py requires:
      - broker

    These dependencies are not represented in settings.py, so they must be
    explicitly registered before startup.
    """
    deps = app.dependencies

    if service_name == "feeds":
        if app.settings.startup.require_runtime_instruments and deps.runtime_instruments is None:
            raise DependencyError(
                "feeds service requires registered runtime_instruments / instrument_set. "
                "Use register_bootstrap_dependencies(runtime_instruments=...)."
            )
        if deps.feed_adapter is None:
            raise DependencyError(
                "feeds service requires registered feed_adapter / market_data_adapter. "
                "Use register_bootstrap_dependencies(feed_adapter=...)."
            )

    if service_name == "execution":
        if deps.broker is None:
            raise DependencyError(
                "execution service requires registered broker. "
                "Use register_bootstrap_dependencies(broker=...)."
            )



def _normalize_runtime_instruments_for_services(runtime_instruments: Any | None) -> Any | None:
    """
    Normalize domain runtime instruments into the exact frozen service-facing
    attribute surface required by feeds.py.

    Current proven compatibility rule:
    - if object has current_future but not future, expose a thin compat view
    """
    if runtime_instruments is None:
        return None

    has_current_future = hasattr(runtime_instruments, "current_future")
    has_future = hasattr(runtime_instruments, "future")

    if has_current_future and not has_future:
        return RuntimeInstrumentSetCompat(runtime_instruments)

    return runtime_instruments


def build_runtime_context(
    *,
    app: AppContext,
    shutdown: ShutdownSignal,
    service_name: str,
    replay_start_wall_time_ns: int | None,
) -> RuntimeContext:
    identity = build_service_identity(app, service_name)
    _require_service_dependencies(app, identity.service_name)

    normalized_runtime_instruments = _normalize_runtime_instruments_for_services(
        app.dependencies.runtime_instruments
    )

    return RuntimeContext(
        settings=app.settings,
        redis=app.redis,
        clock=app.clock,
        shutdown=shutdown,
        app=app,
        identity=identity,
        service_name=identity.service_name,
        instance_id=identity.instance_id,
        replay_start_wall_time_ns=replay_start_wall_time_ns,
        runtime_instruments=normalized_runtime_instruments,
        instrument_set=normalized_runtime_instruments,
        feed_adapter=app.dependencies.feed_adapter,
        market_data_adapter=app.dependencies.feed_adapter,
        broker=app.dependencies.broker,
    )


def _runtime_service_names() -> tuple[str, ...]:
    """
    Return the frozen runtime supervision set.

    This is intentionally NOT derived from opportunistic tree scans or alternate
    bootstrap roots. The supervised runtime set is frozen here and must remain
    aligned with the project tree contract.
    """
    return tuple(FROZEN_RUNTIME_SERVICE_PATHS.keys())


def _runtime_service_module_path(service_name: str) -> str:
    service = _require_non_empty_str(service_name, field_name="service_name").lower()
    try:
        return FROZEN_RUNTIME_SERVICE_PATHS[service]
    except KeyError as exc:
        known = ", ".join(sorted(FROZEN_RUNTIME_SERVICE_PATHS))
        raise MainError(
            f"unknown runtime service {service!r}; expected one of: {known}"
        ) from exc


def _validate_target_service(target_service: str) -> str:
    service = _require_non_empty_str(target_service, field_name="service").lower()
    if service == DEFAULT_SERVICE:
        return service

    allowed = set(_runtime_service_names())
    if service not in allowed:
        known = ", ".join(sorted((DEFAULT_SERVICE, *allowed)))
        raise MainError(f"unknown service {service!r}; expected one of: {known}")
    return service


def _validate_service_registry_surface() -> None:
    """
    Validate that names.SERVICE_REGISTRY remains the frozen ownership registry
    surface, while main.py supervises only the frozen runtime subset.

    SERVICE_REGISTRY may contain non-runtime ownership entries, but for runtime
    services the registry path truth must exactly match the frozen tree.
    """
    for service_name, expected_module_path in FROZEN_RUNTIME_SERVICE_PATHS.items():
        try:
            service_def = names.get_service_def(service_name)
        except Exception as exc:
            raise RegistryError(
                f"runtime service {service_name!r} missing from names.SERVICE_REGISTRY: {exc}"
            ) from exc

        module_path = getattr(service_def, "module_path", None)
        if not isinstance(module_path, str):
            raise RegistryError(
                f"runtime service {service_name!r} has invalid module_path in SERVICE_REGISTRY: "
                f"{module_path!r}"
            )

        if module_path != expected_module_path:
            raise RegistryError(
                f"runtime service {service_name!r} registry path mismatch: "
                f"expected {expected_module_path!r}, got {module_path!r}"
            )

        if module_path in FORBIDDEN_RUNTIME_PATHS:
            raise RegistryError(
                f"runtime service {service_name!r} points at forbidden module path {module_path!r}"
            )


def _validate_service_module_contract(service_name: str, module: ModuleType) -> None:
    """
    Strict runtime service contract validation.

    Ensures:
      - Module imports cleanly.
      - Exports a callable run.
      - The run callable accepts exactly one parameter named 'context'.
      - The module lives under app.mme_scalpx.services.*.
      - Module name does not drift to stale or forbidden variants.
    """
    runner = getattr(module, "run", None)
    if runner is None:
        raise ServiceContractError(
            f"runtime service {service_name!r} must export a 'run' attribute"
        )
    if not callable(runner):
        raise ServiceContractError(
            f"runtime service {service_name!r} attribute 'run' is not callable"
        )

    try:
        sig = inspect.signature(runner)
    except ValueError as exc:
        raise ServiceContractError(
            f"runtime service {service_name!r} has invalid signature: {exc}"
        ) from exc

    params = list(sig.parameters.values())
    if len(params) != 1:
        raise ServiceContractError(
            f"runtime service {service_name!r} run() must accept exactly one parameter, got {len(params)}"
        )

    param = params[0]
    if param.name != "context":
        raise ServiceContractError(
            f"runtime service {service_name!r} run() parameter must be named 'context', got {param.name!r}"
        )

    module_file = getattr(module, "__file__", None)
    if module_file is not None:
        module_path = Path(module_file).resolve()
        normalized_path = str(module_path).replace("\\", "/")
        if "/app/mme_scalpx/services/" not in normalized_path:
            raise ServiceContractError(
                f"runtime service {service_name!r} module file {module_path} is not under app.mme_scalpx.services"
            )

    module_name = module.__name__
    expected_module_name = _runtime_service_module_path(service_name)
    if module_name != expected_module_name:
        raise ServiceContractError(
            f"runtime service {service_name!r} loaded unexpected module name: "
            f"expected {expected_module_name!r}, got {module_name!r}"
        )

    if module_name in FORBIDDEN_RUNTIME_PATHS:
        raise ServiceContractError(
            f"runtime service {service_name!r} loaded forbidden module path {module_name!r}"
        )


def load_service_module(service_name: str) -> ModuleType:
    normalized = _require_non_empty_str(service_name, field_name="service_name").lower()
    expected_module_path = _runtime_service_module_path(normalized)

    try:
        service_def = names.get_service_def(normalized)
    except Exception as exc:
        raise ServiceLoadError(
            f"runtime service {normalized!r} missing from names.SERVICE_REGISTRY: {exc}"
        ) from exc

    module_path = getattr(service_def, "module_path", None)
    if not isinstance(module_path, str):
        raise ServiceLoadError(
            f"runtime service {normalized!r} has invalid module_path in registry: {module_path!r}"
        )

    if module_path != expected_module_path:
        raise ServiceLoadError(
            f"runtime service {normalized!r} must resolve to frozen module path "
            f"{expected_module_path!r}, got {module_path!r}"
        )

    if module_path in FORBIDDEN_RUNTIME_PATHS:
        raise ServiceLoadError(
            f"runtime service {normalized!r} points at forbidden module path {module_path!r}"
        )

    try:
        module = importlib.import_module(module_path)
    except ImportError as exc:
        raise ServiceLoadError(
            f"failed to import runtime service {normalized!r} from {module_path!r}: {exc}"
        ) from exc

    if module.__name__ != module_path:
        raise ServiceLoadError(
            f"runtime service {normalized!r} imported unexpected module name: "
            f"expected {module_path!r}, got {module.__name__!r}"
        )

    return module


def resolve_service_runner(module: ModuleType, *, service_name: str) -> ServiceRunner:
    """Resolve canonical run(context) entrypoint from a runtime service module."""
    runner = getattr(module, "run", None)
    if runner is None or not callable(runner):
        raise ServiceLoadError(
            f"runtime service {service_name!r} must export callable run(context)"
        )
    return runner


def _validate_frozen_service_modules() -> None:
    """Eagerly import and validate all frozen runtime service modules."""
    for service_name in _runtime_service_names():
        module = load_service_module(service_name)
        _validate_service_module_contract(service_name, module)


def _derive_replay_start_wall_time_ns(
    *,
    settings: AppSettings,
    explicit_value: int | None,
) -> int | None:
    """
    Resolve replay start wall time from CLI first, then env var.

    Replay mode requires an explicit start wall-time anchor.
    """
    if explicit_value is not None:
        if isinstance(explicit_value, bool) or explicit_value < 0:
            raise BootstrapError("replay_start_wall_time_ns must be >= 0")
        return explicit_value

    raw = os.environ.get(REPLAY_START_ENV_VAR)
    normalized = _normalize_optional_str(raw)
    if normalized is None:
        if settings.runtime.is_replay:
            raise BootstrapError(
                "replay mode requires replay start wall time. "
                f"pass --replay-start-wall-time-ns or set {REPLAY_START_ENV_VAR}."
            )
        return None

    try:
        value = int(normalized)
    except ValueError as exc:
        raise BootstrapError(
            f"{REPLAY_START_ENV_VAR} must be an integer epoch nanoseconds"
        ) from exc

    if value < 0:
        raise BootstrapError(f"{REPLAY_START_ENV_VAR} must be >= 0")

    return value


def bootstrap_clock(
    settings: AppSettings,
    *,
    replay_start_wall_time_ns: int | None,
) -> BaseClock:
    """Build and install the canonical process clock."""
    try:
        clock = build_clock(
            replay=settings.runtime.is_replay,
            replay_start_wall_time_ns=replay_start_wall_time_ns,
            replay_start_monotonic_ns=0,
        )
        return init_clock(clock)
    except ReplayClockError as exc:
        raise BootstrapError(f"clock bootstrap failed: {exc}") from exc
    except Exception as exc:
        raise BootstrapError(f"clock bootstrap failed: {exc}") from exc


def verify_redis_connectivity(app: AppContext) -> None:
    """Fail fast if Redis is unreachable or misconfigured."""
    try:
        ok = bool(redisx.ping_redis(client=app.redis.sync))
    except Exception as exc:
        raise BootstrapError(f"Redis connectivity check failed: {exc}") from exc

    if not ok:
        raise BootstrapError("Redis ping returned false")


def verify_login_health_if_required(app: AppContext) -> None:
    """
    Optionally require login health before startup.

    login.py is not runtime-supervised here, but if startup policy requires its
    heartbeat, main.py should validate that canonical health surface.
    """
    if not app.settings.startup.require_login_health:
        return

    try:
        raw = redisx.hgetall(names.KEY_HEALTH_LOGIN, client=app.redis.sync)
    except Exception as exc:
        raise BootstrapError(f"failed reading login health: {exc}") from exc

    if not raw:
        raise BootstrapError("startup requires login health, but login heartbeat is empty")

    status = str(raw.get("status", "")).strip().upper()
    allowed = {names.HEALTH_STATUS_OK, names.HEALTH_STATUS_WARN}
    if status not in allowed:
        raise BootstrapError(f"startup requires login health, got status={status!r}")


def _publish_main_state(
    *,
    app: AppContext,
    replay_start_wall_time_ns: int | None,
) -> None:
    """
    Publish minimal main-owned latest-state surfaces.

    These writes stay within names.py ownership:
    - HASH_STATE_RUNTIME
    - HASH_STATE_MODE
    - HASH_PARAMS_MME_META
    """
    service_name = names.SERVICE_MAIN
    instance_id = app.instance_name(service_name)
    now_ns = int(app.clock.wall_time_ns())

    try:
        redisx.write_hash_fields(
            names.HASH_STATE_RUNTIME,
            {
                "service_name": service_name,
                "instance_id": instance_id,
                "node_name": app.node_name,
                "pid": str(app.pid),
                "app_name": app.app_name,
                "app_env": app.env,
                "runtime_mode": app.settings.runtime.runtime_mode,
                "is_replay": "1" if app.settings.runtime.is_replay else "0",
                "replay_start_wall_time_ns": (
                    "" if replay_start_wall_time_ns is None else str(replay_start_wall_time_ns)
                ),
                "updated_at_ns": str(now_ns),
            },
            client=app.redis.sync,
        )

        control_mode = (
            names.CONTROL_MODE_REPLAY
            if app.settings.runtime.is_replay
            else names.CONTROL_MODE_NORMAL
        )
        redisx.write_hash_fields(
            names.HASH_STATE_MODE,
            {
                "service_name": service_name,
                "instance_id": instance_id,
                "mode": control_mode,
                "updated_at_ns": str(now_ns),
            },
            client=app.redis.sync,
        )

        redisx.write_hash_fields(
            names.HASH_PARAMS_MME_META,
            {
                "service_name": service_name,
                "instance_id": instance_id,
                "contracts_version": str(names.CONTRACTS_VERSION),
                "schema_version": str(names.DEFAULT_SCHEMA_VERSION),
                "updated_at_ns": str(now_ns),
            },
            client=app.redis.sync,
        )
    except Exception as exc:
        raise BootstrapError(f"failed to publish main-owned state: {exc}") from exc


def maybe_bootstrap_consumer_groups(
    *,
    replay: bool,
    enabled: bool,
) -> dict[str, tuple[str, ...]]:
    """Optionally create/validate consumer groups declared by names.py."""
    if not enabled:
        LOGGER.info("consumer_group_bootstrap_disabled")
        return {}

    specs = names.get_group_specs(replay=replay)
    try:
        redisx.bootstrap_group_specs(replay=replay)
    except Exception as exc:
        raise BootstrapError(f"consumer-group bootstrap failed: {exc}") from exc

    LOGGER.info(
        "consumer_group_bootstrap_completed replay=%s stream_count=%s",
        replay,
        len(specs),
    )
    return specs


def build_doctor_report(
    *,
    app: AppContext,
    replay_start_wall_time_ns: int | None,
    bootstrap_groups_enabled: bool,
) -> dict[str, Any]:
    """Build a lightweight operational report without starting runtime services."""
    redis_ok: bool
    redis_error: str | None = None
    try:
        redis_ok = bool(redisx.ping_redis(client=app.redis.sync))
    except Exception as exc:
        redis_ok = False
        redis_error = str(exc)

    runtime_service_defs: dict[str, dict[str, Any]] = {}
    for service_name in _runtime_service_names():
        service_def = names.get_service_def(service_name)
        runtime_service_defs[service_name] = {
            "module_path": service_def.module_path,
            "owns_heartbeat": getattr(service_def, "owns_heartbeat", None),
            "owns_lock": getattr(service_def, "owns_lock", None),
            "description": getattr(service_def, "description", None),
        }

    return {
        "project": getattr(names, "PROJECT_NAME", "mme_scalpx"),
        "contracts_version": getattr(names, "CONTRACTS_VERSION", None),
        "schema_version": getattr(names, "DEFAULT_SCHEMA_VERSION", None),
        "runtime_mode": app.settings.runtime.runtime_mode,
        "app_env": app.settings.app_env,
        "replay": app.settings.runtime.is_replay,
        "replay_start_wall_time_ns": replay_start_wall_time_ns,
        "node_name": app.node_name,
        "pid": app.pid,
        "redis": {
            "ok": redis_ok,
            "error": redis_error,
            "masked_url": app.settings.redis.masked_url,
            "client_name": app.settings.redis.client_name,
            "uses_tls": app.settings.redis.uses_tls,
            "stream_maxlen_approx": app.settings.redis.stream_maxlen_approx,
            "xread_count": app.settings.redis.xread_count,
            "xread_block_ms": app.settings.redis.xread_block_ms,
        },
        "clock": {
            "is_replay": app.clock.is_replay,
            "wall_time_ns": app.clock.wall_time_ns(),
            "monotonic_ns": app.clock.monotonic_ns(),
        },
        "bootstrap_groups_enabled": bootstrap_groups_enabled,
        "group_specs": names.get_group_specs(replay=app.settings.runtime.is_replay),
        "runtime_services": runtime_service_defs,
        "frozen_runtime_paths": dict(FROZEN_RUNTIME_SERVICE_PATHS),
        "dependencies": app.dependencies.to_safe_dict(),
    }


@dataclass(slots=True)
class ServiceThreadRecord:
    service_name: str
    thread: threading.Thread | None
    context: RuntimeContext
    exception: BaseException | None = None
    return_code: int = 0


def _run_service_once(context: RuntimeContext) -> int:
    """Run one runtime service module once in the current thread."""
    module = load_service_module(context.service_name)
    runner = resolve_service_runner(module, service_name=context.service_name)

    LOGGER.info(
        "runtime_service_starting service=%s module=%s instance_id=%s replay=%s",
        context.service_name,
        module.__name__,
        context.instance_id,
        context.is_replay,
    )

    result = runner(context)
    exit_code = 0 if result is None else int(result)

    LOGGER.info(
        "runtime_service_exited service=%s instance_id=%s exit_code=%s",
        context.service_name,
        context.instance_id,
        exit_code,
    )
    return exit_code


def run_service(context: RuntimeContext) -> int:
    """Run one runtime service synchronously in the current thread/process."""
    return _run_service_once(context)


def _service_thread_target(record: ServiceThreadRecord) -> None:
    try:
        record.return_code = run_service(record.context)
    except BaseException as exc:  # pragma: no cover
        record.exception = exc
        LOGGER.error(
            "runtime_service_thread_crashed service=%s instance_id=%s error=%s\n%s",
            record.service_name,
            record.context.instance_id,
            exc,
            traceback.format_exc(),
        )
        record.context.shutdown.raise_signal()


def run_all_services(
    *,
    app: AppContext,
    shutdown: ShutdownSignal,
    replay_start_wall_time_ns: int | None,
) -> int:
    """Start all frozen runtime services in dedicated threads and supervise them."""
    records: list[ServiceThreadRecord] = []

    for service_name in _runtime_service_names():
        context = build_runtime_context(
            app=app,
            shutdown=shutdown,
            service_name=service_name,
            replay_start_wall_time_ns=replay_start_wall_time_ns,
        )
        record = ServiceThreadRecord(
            service_name=service_name,
            thread=None,
            context=context,
        )
        record.thread = threading.Thread(
            target=_service_thread_target,
            args=(record,),
            name=f"mme-{service_name}",
            daemon=False,
        )
        records.append(record)

    LOGGER.info("starting_all_runtime_services count=%s", len(records))

    for record in records:
        if record.thread is None:
            raise BootstrapError(
                f"runtime service thread not initialized: {record.service_name}"
            )
        record.thread.start()

    time.sleep(STARTUP_LIVENESS_GRACE_S)
    for record in records:
        if record.thread is None:
            raise BootstrapError(
                f"runtime service thread not initialized: {record.service_name}"
            )
        if not record.thread.is_alive():
            if record.exception is not None:
                raise BootstrapError(
                    f"runtime service thread died during startup: "
                    f"{record.service_name}: {record.exception}"
                )
            raise BootstrapError(
                f"runtime service thread died during startup: {record.service_name}"
            )

    exit_code = 0

    try:
        while True:
            alive = [
                record
                for record in records
                if record.thread is not None and record.thread.is_alive()
            ]
            if not alive:
                break

            crashed = [record for record in records if record.exception is not None]
            if crashed:
                exit_code = 1
                break

            if shutdown.is_set():
                break

            shutdown.wait(SUPERVISOR_POLL_INTERVAL_S)
    finally:
        shutdown.raise_signal()
        for record in records:
            if record.thread is not None:
                record.thread.join(timeout=THREAD_JOIN_TIMEOUT_S)

    crashed = [record for record in records if record.exception is not None]
    if crashed:
        return 1

    nonzero = [record.return_code for record in records if record.return_code != 0]
    if nonzero:
        return nonzero[0]

    return exit_code


def shutdown_application() -> None:
    """Best-effort, idempotent process shutdown."""
    warnings: list[str] = []

    try:
        redisx.close_redis_clients()
    except Exception as exc:  # pragma: no cover
        LOGGER.warning("redis_client_shutdown_warning error=%s", exc)
        warnings.append(str(exc))

    try:
        clear_clock()
    except Exception as exc:  # pragma: no cover
        LOGGER.warning("clock_shutdown_warning error=%s", exc)
        warnings.append(str(exc))

    if warnings:
        LOGGER.info("shutdown_completed_with_warnings count=%s", len(warnings))
    else:
        LOGGER.info("shutdown_completed_cleanly")


def build_arg_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="python -m app.mme_scalpx.main",
        description="ScalpX MME canonical bootstrap/orchestration entrypoint",
    )
    parser.add_argument(
        "--service",
        default=DEFAULT_SERVICE,
        help=(
            f"service to run: {DEFAULT_SERVICE} or one of "
            f"{', '.join(_runtime_service_names())}"
        ),
    )
    parser.add_argument(
        "--bootstrap-provider",
        default=None,
        help=(
            "explicit dependency bootstrap provider in 'module.path:function_name' form. "
            f"If omitted, {BOOTSTRAP_PROVIDER_ENV_VAR} is used when set."
        ),
    )
    parser.add_argument(
        "--doctor",
        action="store_true",
        help="print diagnostic bootstrap report and exit",
    )
    parser.add_argument(
        "--skip-group-bootstrap",
        action="store_true",
        help="disable Redis consumer-group bootstrap during startup",
    )
    parser.add_argument(
        "--replay-start-wall-time-ns",
        type=int,
        default=None,
        help=(
            "replay start wall time in epoch nanoseconds. "
            f"required in replay mode unless {REPLAY_START_ENV_VAR} is set."
        ),
    )
    return parser


def main(argv: Sequence[str] | None = None) -> int:
    parser = build_arg_parser()
    args = parser.parse_args(list(argv) if argv is not None else None)

    target_service = _validate_target_service(str(args.service))
    settings = get_settings()

    configure_logging(settings)

    shutdown = build_shutdown_signal()
    install_signal_handlers(shutdown)

    replay_start_wall_time_ns = _derive_replay_start_wall_time_ns(
        settings=settings,
        explicit_value=args.replay_start_wall_time_ns,
    )

    clock = bootstrap_clock(
        settings,
        replay_start_wall_time_ns=replay_start_wall_time_ns,
    )

    maybe_register_bootstrap_dependencies(
        provider_ref=args.bootstrap_provider,
    )

    app = build_app_context(settings=settings, clock=clock)

    try:
        _validate_service_registry_surface()
        _validate_frozen_service_modules()

        if args.doctor:
            report = build_doctor_report(
                app=app,
                replay_start_wall_time_ns=replay_start_wall_time_ns,
                bootstrap_groups_enabled=not args.skip_group_bootstrap,
            )
            print(json.dumps(report, ensure_ascii=False, indent=2, sort_keys=True))
            return 0

        if settings.startup.require_redis_ping:
            verify_redis_connectivity(app)

        verify_login_health_if_required(app)
        _publish_main_state(
            app=app,
            replay_start_wall_time_ns=replay_start_wall_time_ns,
        )

        maybe_bootstrap_consumer_groups(
            replay=settings.runtime.is_replay,
            enabled=not args.skip_group_bootstrap,
        )

        if target_service == DEFAULT_SERVICE:
            return run_all_services(
                app=app,
                shutdown=shutdown,
                replay_start_wall_time_ns=replay_start_wall_time_ns,
            )

        context = build_runtime_context(
            app=app,
            shutdown=shutdown,
            service_name=target_service,
            replay_start_wall_time_ns=replay_start_wall_time_ns,
        )
        return run_service(context)

    except KeyboardInterrupt:
        LOGGER.warning("interrupted_by_user")
        shutdown.raise_signal()
        return 130
    except MainError as exc:
        LOGGER.error("bootstrap_orchestration_failed error=%s", exc)
        shutdown.raise_signal()
        return 1
    except Exception as exc:  # pragma: no cover
        LOGGER.error("unhandled_fatal_error error=%s\n%s", exc, traceback.format_exc())
        shutdown.raise_signal()
        return 1
    finally:
        shutdown_application()


if __name__ == "__main__":
    raise SystemExit(main())