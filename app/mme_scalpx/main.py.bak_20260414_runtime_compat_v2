    Redis transport semantics still remain owned by core.redisx.
    """

    sync: Any
    async_: Any | None = None


@dataclass(frozen=True, slots=True)
class BootstrapDependencies:
    """
    Explicit externally-registered runtime dependencies.

    These are not business-state owners and do not create an alternate startup
    root. They only satisfy proven service run(context) contracts.
    """

    runtime_instruments: Any | None = None
    feed_adapter: Any | None = None
    broker: Any | None = None

    def to_safe_dict(self) -> dict[str, bool]:
        return {
            "runtime_instruments_registered": self.runtime_instruments is not None,
            "feed_adapter_registered": self.feed_adapter is not None,
            "broker_registered": self.broker is not None,
        }


_BOOTSTRAP_DEPENDENCY_LOCK: Final[threading.RLock] = threading.RLock()
_BOOTSTRAP_DEPENDENCIES: BootstrapDependencies = BootstrapDependencies()


def register_bootstrap_dependencies(
    *,
    runtime_instruments: Any | None = None,
    feed_adapter: Any | None = None,
    broker: Any | None = None,
) -> None:
    """
    Register external runtime dependencies required by frozen service contracts.

    This function does not start any service and does not supersede main.py as
    the only composition root. It only loads explicit objects that main.py will
    place into RuntimeContext when appropriate.
    """
    global _BOOTSTRAP_DEPENDENCIES
    with _BOOTSTRAP_DEPENDENCY_LOCK:
        _BOOTSTRAP_DEPENDENCIES = BootstrapDependencies(
            runtime_instruments=runtime_instruments,
            feed_adapter=feed_adapter,
            broker=broker,
        )


def clear_bootstrap_dependencies() -> None:
    """Clear all externally-registered runtime dependencies."""
    global _BOOTSTRAP_DEPENDENCIES
    with _BOOTSTRAP_DEPENDENCY_LOCK:
        _BOOTSTRAP_DEPENDENCIES = BootstrapDependencies()


def get_bootstrap_dependencies() -> BootstrapDependencies:
    """Return the currently registered runtime dependency bundle."""
    with _BOOTSTRAP_DEPENDENCY_LOCK:
        return _BOOTSTRAP_DEPENDENCIES


def _parse_bootstrap_provider_ref(raw: str) -> tuple[str, str]:
    """
    Parse explicit bootstrap provider reference of the form:

        module.path:function_name
    """
    normalized = _require_non_empty_str(raw, field_name="bootstrap_provider")
    if ":" not in normalized:
        raise BootstrapError(
            "bootstrap provider must be in 'module.path:function_name' form"
        )
    module_path, func_name = normalized.split(":", 1)
    module_path = _require_non_empty_str(module_path, field_name="bootstrap_provider.module")
    func_name = _require_non_empty_str(func_name, field_name="bootstrap_provider.function")
    return module_path, func_name


def _load_bootstrap_provider(raw: str) -> Any:
    """
    Import and validate the explicit bootstrap provider callable.

    The provider is expected to be callable and may either:
    - call register_bootstrap_dependencies(...) directly, or
    - return a dict containing any of:
        runtime_instruments, feed_adapter, broker
    """
    module_path, func_name = _parse_bootstrap_provider_ref(raw)

    try:
        module = importlib.import_module(module_path)
    except Exception as exc:
        raise BootstrapError(
            f"failed to import bootstrap provider module {module_path!r}: {exc}"
        ) from exc

    provider = getattr(module, func_name, None)
    if provider is None or not callable(provider):
        raise BootstrapError(
            f"bootstrap provider {module_path!r}:{func_name!r} is not callable"
        )

    return provider


def maybe_register_bootstrap_dependencies(
    *,
    provider_ref: str | None,
) -> None:
    """
    Optionally register explicit runtime dependencies before AppContext is built.

    This preserves main.py as the sole composition root while allowing a
    separately-frozen provider callable to supply proven external dependencies
    in-process.
    """
    ref = _normalize_optional_str(provider_ref)
    if ref is None:
        ref = _normalize_optional_str(os.environ.get(BOOTSTRAP_PROVIDER_ENV_VAR))

    if ref is None:
        LOGGER.info("bootstrap_provider_not_configured")
        return

    provider = _load_bootstrap_provider(ref)
    result = provider()

    if result is None:
        LOGGER.info("bootstrap_provider_completed provider=%s mode=side_effect", ref)
        return

    if not isinstance(result, dict):
        raise BootstrapError(
            "bootstrap provider must return None or dict with dependency keys"
        )

    allowed = {"runtime_instruments", "feed_adapter", "broker"}
    unknown = set(result.keys()) - allowed
    if unknown:
        raise BootstrapError(
            "bootstrap provider returned unknown dependency keys: "
            + ", ".join(sorted(map(str, unknown)))
        )

    register_bootstrap_dependencies(
        runtime_instruments=result.get("runtime_instruments"),
        feed_adapter=result.get("feed_adapter"),
        broker=result.get("broker"),
    )

    LOGGER.info(
        "bootstrap_provider_completed provider=%s mode=returned_dict runtime_instruments=%s feed_adapter=%s broker=%s",
        ref,
        int(result.get("runtime_instruments") is not None),
        int(result.get("feed_adapter") is not None),
        int(result.get("broker") is not None),
    )


