class MainError(RuntimeError):
    """Base exception for orchestration/bootstrap failures."""


class BootstrapError(MainError):
    """Raised when bootstrap sequencing fails."""


class ServiceLoadError(MainError):
    """Raised when a runtime service module cannot be loaded or is invalid."""


class RegistryError(MainError):
    """Raised when SERVICE_REGISTRY is inconsistent with frozen runtime truth."""


class ServiceContractError(MainError):
    """Raised when a runtime service module violates the run(context) contract."""


class DependencyError(MainError):
    """Raised when required external runtime dependencies are missing."""


class ServiceRunner(Protocol):
    """
    Canonical runtime service entrypoint contract.

    Every runtime service module must export:

        def run(context: RuntimeContext) -> int | None
    """

    def __call__(self, context: "RuntimeContext") -> int | None:
        ...


def _require_non_empty_str(value: Any, *, field_name: str) -> str:
    if not isinstance(value, str):
        raise MainError(f"{field_name} must be a non-empty string")
    normalized = value.strip()
    if not normalized:
        raise MainError(f"{field_name} must be a non-empty string")
    return normalized


def _normalize_optional_str(value: Any) -> str | None:
    if value is None:
        return None
    if not isinstance(value, str):
        raise MainError("optional string field must be a string or None")
    normalized = value.strip()
    return normalized or None


class JsonLogFormatter(logging.Formatter):
    """Minimal deterministic JSON log formatter."""

    def __init__(
        self,
        *,
        include_process_id: bool,
        include_thread_name: bool,
    ) -> None:
        super().__init__()
        self._include_process_id = include_process_id
        self._include_thread_name = include_thread_name

    def format(self, record: logging.LogRecord) -> str:
        payload: dict[str, Any] = {
            "ts": datetime.fromtimestamp(record.created, tz=timezone.utc).isoformat(),
            "level": record.levelname,
            "logger": record.name,
            "message": record.getMessage(),
        }

        if self._include_process_id:
            payload["process"] = record.process
        if self._include_thread_name:
            payload["thread"] = record.threadName
        if record.exc_info:
            payload["exc_info"] = self.formatException(record.exc_info)

        return json.dumps(
            payload,
            ensure_ascii=False,
            sort_keys=True,
            separators=(",", ":"),
        )


def configure_logging(settings: AppSettings) -> None:
    """Configure process logging deterministically for this bootstrap cycle."""
    root_logger = logging.getLogger()
    root_logger.handlers.clear()

    level_name = settings.logging.level
    level_value = getattr(logging, level_name, None)
    if not isinstance(level_value, int):
        raise BootstrapError(f"invalid logging level from settings: {level_name!r}")

    handler = logging.StreamHandler(sys.stdout)

    if settings.logging.fmt == "json":
        formatter = JsonLogFormatter(
            include_process_id=settings.logging.include_process_id,
            include_thread_name=settings.logging.include_thread_name,
        )
    else:
        parts = ["%(asctime)s", "%(levelname)s", "%(name)s"]
        if settings.logging.include_process_id:
            parts.append("pid=%(process)d")
        if settings.logging.include_thread_name:
            parts.append("thread=%(threadName)s")
        parts.append("%(message)s")
        formatter = logging.Formatter(" | ".join(parts))

    handler.setFormatter(formatter)
    root_logger.addHandler(handler)
    root_logger.setLevel(level_value)

    LOGGER.info(
        "logging_configured level=%s format=%s",
        settings.logging.level,
        settings.logging.fmt,
    )


@dataclass(slots=True)
class ShutdownSignal:
    """Shared cooperative shutdown signal for all supervised services."""

    _event: threading.Event

    def raise_signal(self) -> None:
        self._event.set()

    def is_set(self) -> bool:
        return self._event.is_set()

    def wait(self, timeout: float | None = None) -> bool:
        return self._event.wait(timeout)


def build_shutdown_signal() -> ShutdownSignal:
    return ShutdownSignal(_event=threading.Event())


def install_signal_handlers(shutdown: ShutdownSignal) -> None:
    """Install cooperative SIGINT/SIGTERM handlers."""

    def _handler(signum: int, _frame: Any) -> None:
        LOGGER.warning("received_shutdown_signal signum=%s", signum)
        shutdown.raise_signal()

    signal.signal(signal.SIGINT, _handler)
    signal.signal(signal.SIGTERM, _handler)


