"""
app/mme_scalpx/integrations/feed_adapter.py

Canonical feed-adapter integration boundary for ScalpX MME.

Responsibilities
----------------
- define the stable feed adapter contract consumed by runtime services
- provide a null adapter for safe bootstrap/testing paths
- provide a thin real Zerodha-backed adapter wrapper over the proven
  websocket transport implementation

Non-responsibilities
--------------------
- no Redis publication
- no snapshot ownership outside adapter-local memory
- no feature extraction
- no strategy logic
- no order placement
- no composition-root ownership
- no service supervision

Freeze rules
------------
- services must depend on this contract boundary, not broker SDK classes
- Zerodha websocket details stay encapsulated in zerodha_feed_adapter.py
- current proven runtime family scope remains:
  future, ce_atm, ce_atm1, pe_atm, pe_atm1
"""

from __future__ import annotations

from dataclasses import dataclass
from typing import Any, Protocol, runtime_checkable

from app.mme_scalpx.domain.instruments import RuntimeInstrumentSet
from app.mme_scalpx.integrations.zerodha_feed_adapter import (
    FeedPollBundle,
    ZerodhaFeedAdapter,
)

VERSION = "mme-feed-adapter-v1-freeze"


class FeedAdapterError(RuntimeError):
    """Base feed adapter error."""


class FeedAdapterValidationError(FeedAdapterError):
    """Raised when adapter construction or usage is invalid."""


@runtime_checkable
class FeedAdapter(Protocol):
    """
    Stable feed-adapter contract for runtime service consumption.

    Required behaviors
    ------------------
    - connect(): establish live transport if needed
    - close(): release transport resources
    - is_connected(): current transport-health indicator
    - poll(): return latest normalized bundle or None

    Notes
    -----
    poll() intentionally returns a transport-normalized bundle, not raw broker
    websocket payloads.
    """

    def connect(self) -> None:
        ...

    def close(self) -> None:
        ...

    def is_connected(self) -> bool:
        ...

    def poll(self, timeout: float = 0.0) -> dict[str, Any] | None:
        ...


@dataclass(frozen=True)
class FeedAdapterInfo:
    adapter_name: str
    version: str
    broker: str
    mode: str


class BaseFeedAdapter:
    """
    Base convenience implementation for feed adapters.

    This class is intentionally minimal and non-transport-owning.
    """

    def info(self) -> FeedAdapterInfo:
        return FeedAdapterInfo(
            adapter_name=self.__class__.__name__,
            version=VERSION,
            broker="unknown",
            mode="base",
        )

    def connect(self) -> None:
        raise NotImplementedError("connect() not implemented")

    def close(self) -> None:
        raise NotImplementedError("close() not implemented")

    def is_connected(self) -> bool:
        raise NotImplementedError("is_connected() not implemented")

    def poll(self, timeout: float = 0.0) -> dict[str, Any] | None:
        raise NotImplementedError("poll() not implemented")


class NullFeedAdapter(BaseFeedAdapter):
    """
    Safe no-op feed adapter.

    Use only for bootstrap/testing paths where live market data is intentionally
    unavailable.
    """

    def __init__(self) -> None:
        self._connected = False

    def info(self) -> FeedAdapterInfo:
        return FeedAdapterInfo(
            adapter_name=self.__class__.__name__,
            version=VERSION,
            broker="none",
            mode="null",
        )

    def connect(self) -> None:
        self._connected = False

    def close(self) -> None:
        self._connected = False

    def is_connected(self) -> bool:
        return False

    def poll(self, timeout: float = 0.0) -> dict[str, Any] | None:
        return None


class ZerodhaLiveFeedAdapter(BaseFeedAdapter):
    """
    Canonical real feed adapter wrapping the proven Zerodha websocket transport.

    This wrapper exists so runtime services depend only on the stable
    feed_adapter.py contract boundary, not directly on Zerodha transport code.
    """

    def __init__(
        self,
        *,
        runtime_instruments: RuntimeInstrumentSet,
        connect_timeout_s: float = 15.0,
        poll_queue_size: int = 1024,
    ) -> None:
        if runtime_instruments is None:
            raise FeedAdapterValidationError("runtime_instruments must be provided")

        self._runtime_instruments = runtime_instruments
        self._transport = ZerodhaFeedAdapter(
            runtime_instruments=runtime_instruments,
            connect_timeout_s=connect_timeout_s,
            poll_queue_size=poll_queue_size,
        )

    def info(self) -> FeedAdapterInfo:
        return FeedAdapterInfo(
            adapter_name=self.__class__.__name__,
            version=VERSION,
            broker="zerodha",
            mode="live",
        )

    @property
    def runtime_instruments(self) -> RuntimeInstrumentSet:
        return self._runtime_instruments

    @property
    def subscribed_tokens(self) -> list[int]:
        return self._transport.subscribed_tokens

    @property
    def last_error(self) -> str | None:
        return self._transport.last_error

    def connect(self) -> None:
        self._transport.connect()

    def close(self) -> None:
        self._transport.close()

    def is_connected(self) -> bool:
        return self._transport.is_connected()

    def poll(self, timeout: float = 0.0) -> dict[str, Any] | None:
        bundle = self._transport.poll(timeout=timeout)
        if bundle is None:
            return None
        if isinstance(bundle, FeedPollBundle):
            return bundle.to_dict()
        if hasattr(bundle, "to_dict"):
            return bundle.to_dict()
        raise FeedAdapterValidationError(
            f"unexpected transport poll bundle type: {type(bundle)!r}"
        )


def build_real_feed_adapter(
    *,
    runtime_instruments: RuntimeInstrumentSet,
    broker: str = "zerodha",
) -> FeedAdapter:
    """
    Thin factory for runtime/provider wiring.

    Current proven live implementation:
    - zerodha
    """
    broker_key = str(broker).strip().lower()
    if broker_key == "zerodha":
        return ZerodhaLiveFeedAdapter(runtime_instruments=runtime_instruments)
    raise FeedAdapterValidationError(f"unsupported real feed adapter broker: {broker!r}")
